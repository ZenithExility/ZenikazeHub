-- Função para logs do cliente
local function cloudLog(message, level)
    level = level or "INFO"
    local timestamp = os.date("%H:%M:%S")
    local levelColor = {
        ["INFO"] = "🟦",
        ["SUCCESS"] = "🟢", 
        ["WARNING"] = "🟡",
        ["ERROR"] = "🔴",
        ["CLOUD"] = "☁️",
        ["SERVER"] = "🎯"
    }
    
    local icon = levelColor[level] or "ℹ️"
    local prefix = string.format("[%s] %s Zenikaze Cloud:", timestamp, icon)
    local fullMessage = string.format("%s %s", prefix, message)
    
    print(fullMessage)
    cache.lastNotification = message
    
    if getgenv().ZENIKAZE_CLOUD_CONFIG.debugMode then
        warn(string.format("[DEBUG %s] %s", timestamp, message))
    end
end

-- Função para testar conexão com a nuvem
local function testCloudConnection()
    local testEndpoints = {
        getgenv().ZENIKAZE_CLOUD_CONFIG.cloudServer .. "/api/status",
        getgenv().ZENIKAZE_CLOUD_CONFIG.cloudServer .. "/"
    }
    
    for _, endpoint in ipairs(testEndpoints) do
        local testMethods = {
            function()
                if http_request then
                    return http_request({
                        Url = endpoint,
                        Method = "GET",
                        Headers = {
                            ["User-Agent"] = "Zenikaze-Cloud-Client/" .. getgenv().ZENIKAZE_CLOUD_CONFIG.version,
                            ["X-Client-ID"] = cache.sessionId,
                            ["X-Room-ID"] = getgenv().ZENIKAZE_CLOUD_CONFIG.roomId
                        },
                        Timeout = 15
                    })
                end
                return false
            end,
            function()
                if request then
                    return request({
                        Url = endpoint,
                        Method = "GET",
                        Headers = {
                            ["User-Agent"] = "Zenikaze-Cloud-Client"
                        },
                        Timeout = 15
                    })
                end
                return false
            end
        }
        
        for _, method in ipairs(testMethods) do
            local success, response = pcall(method)
            if success and response and (response.StatusCode == 200 or response.Success) then
                cache.connectionStatus = "CONNECTED"
                cache.roomConnected = getgenv().ZENIKAZE_CLOUD_CONFIG.roomId
                return true, endpoint
            end
        end
    end
    
    cache.connectionStatus = "OFFLINE"
    return false, nil
end

-- Função para obter valor do brainrot (otimizada)
local function getBrainrotValue(object)
    if not object or not object.Parent then return 0 end
    
    local success, value = pcall(function()
        local descendants = object:GetDescendants()
        
        for i = 1, math.min(#descendants, 50) do  -- Limitar busca para performance
            local descendant = descendants[i]
            
            if descendant:IsA("TextLabel") and descendant.Text then
                local text = descendant.Text
                
                -- Formato Bilhões: "1.5B/sec"
                local bValue = text:match("([%d%.]+)B/?[sS]?e?c?")
                if bValue then
                    local num = tonumber(bValue)
                    if num then return num * 1000000000 end
                end
                
                -- Formato Milhões: "5.2M/sec"
                local mValue = text:match("([%d%.]+)M/?[sS]?e?c?")
                if mValue then
                    local num = tonumber(mValue)
                    if num then return num * 1000000 end
                end
                
                -- Formato números grandes: "1234567"
                local bigNumber = text:match("([%d]+)/?[sS]?e?c?")
                if bigNumber and #bigNumber >= 7 then
                    local num = tonumber(bigNumber)
                    if num and num >= 1000000 then return num end
                end
                
                -- Formato K: "1000K/sec"
                local kValue = text:match("([%d%.]+)K/?[sS]?e?c?")
                if kValue then
                    local num = tonumber(kValue)
                    if num and num >= 100 then return num * 1000 end
                end
            end
        end
        return 0
    end)
    
    return success and value or 0
end

-- Função para detectar raridade (otimizada)
local function getRarityFromObject(object)
    if not object or not object.Parent then return nil end
    
    local success, result = pcall(function()
        local descendants = object:GetDescendants()
        
        for i = 1, math.min(#descendants, 20) do
            local descendant = descendants[i]
            
            -- Procurar por TextLabel com raridade
            if descendant:IsA("TextLabel") then
                if descendant.Name == "Rarity" then
                    return descendant.Text:gsub("%s+", "")
                end
                
                if descendant.Name == "DisplayName" then
                    local displayText = descendant.Text
                    for rarity in displayText:gmatch("%[([^%]]+)%]") do
                        return rarity
                    end
                end
            end
        end
        
        -- Fallback: detectar por cor do objeto
        if object:IsA("BasePart") then
            local color = object.Color
            if color == Color3.fromRGB(100, 100, 100) then return "Secret" end
            if color == Color3.fromRGB(180, 40, 180) then return "BrainrotGod" end
        end
        
        return nil
    end)
    
    return success and result or nil
end

-- Função para obter nome do item
local function getDisplayName(object)
    local success, result = pcall(function()
        local descendants = object:GetDescendants()
        
        for i = 1, math.min(#descendants, 15) do
            local child = descendants[i]
            if child:IsA("TextLabel") and child.Name == "DisplayName" then
                return child.Text
            end
        end
        return object.Name
    end)
    
    return success and result or (object.Name or "Unknown")
end

-- Função para formatar valor
local function formatValue(brainrotValue)
    if brainrotValue >= 1000000000 then
        return string.format("%.1fB/sec", brainrotValue / 1000000000)
    elseif brainrotValue >= 1000000 then
        return string.format("%.1fM/sec", brainrotValue / 1000000)
    elseif brainrotValue >= 1000 then
        return string.format("%.1fK/sec", brainrotValue / 1000)
    else
        return string.format("%.0f/sec", brainrotValue)
    end
end

