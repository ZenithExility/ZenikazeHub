-- Função para gerar ID único do brainrot (sem plot owner)
local function getBrainrotId(brainrot)
    return brainrot.name .. "|" .. brainrot.rarity .. "|" .. (brainrot.value or "")
end

-- Função para comparar se os brainhots mudaram
local function brainhotsChanged(currentBrainhots)
    if #currentBrainhots ~= #cache.lastBrainhots then
        return true
    end
    
    local currentIds = {}
    for _, brainrot in pairs(currentBrainhots) do
        currentIds[getBrainrotId(brainrot)] = true
    end
    
    local lastIds = {}
    for _, brainrot in pairs(cache.lastBrainhots) do
        lastIds[getBrainrotId(brainrot)] = true
    end
    
    for id, _ in pairs(currentIds) do
        if not lastIds[id] then
            return true
        end
    end
    
    for id, _ in pairs(lastIds) do
        if not currentIds[id] then
            return true
        end
    end
    
    return false
end

task.spawn(function()
    -- Zenikaze Hub Cloud Scanner Active - Running silently (1M+ Range)
    
    while true do
        if getgenv().ZENIKAZE_CONFIG.autoJoinEnabled then
            local highValueBrainhots = checkForHighValueBrainhots()
            
            if #highValueBrainhots > 0 then
                local currentTime = tick()
                
                -- Só enviar para cloud se os brainhots mudaram
                if brainhotsChanged(highValueBrainhots) then
                    -- High value brainhots found - processing silently
                    
                    -- Verificar cooldown
                    if currentTime - cache.lastNotificationTime >= getgenv().ZENIKAZE_CONFIG.cooldownTime then
                        local cloudSuccess = sendToCloud(highValueBrainhots, game.JobId)
                        
                        if cloudSuccess then
                            cache.lastNotificationTime = currentTime
                            cache.lastBrainhots = highValueBrainhots
                            -- Data sent to cloud successfully
                        end
                    else
                        local timeLeft = getgenv().ZENIKAZE_CONFIG.cooldownTime - (currentTime - cache.lastNotificationTime)
                        -- Cooldown active
                        cache.lastBrainhots = highValueBrainhots -- Atualizar cache mesmo no cooldown
                    end
                else
                    -- Same brainhots detected, no cloud update sent
                end
            else
                -- Se não encontrou nada, limpar o cache
                if #cache.lastBrainhots > 0 then
                    cache.lastBrainhots = {}
                    -- No brainhots found, cache cleared
                end
            end
        end
        
        task.wait(getgenv().ZENIKAZE_CONFIG.scanInterval)
    end
end)

