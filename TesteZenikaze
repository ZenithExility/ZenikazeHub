-- LocalScript — Aimbot Web Slinger / Laser Cape (sem notificações / sem UI / sem equipar)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- Config
local MAX_DISTANCE = 200
local COOLDOWN = 0.2
local lastFire = 0

-- Candidatos de remotes (ordem de tentativa)
local REMOTE_CHAINS = {
	{"Packages","Net","RE/UseItem"},
	{"Net","RE/UseItem"},
	{"RE/UseItem"},
	{"Remotes","UseItem"},
	{"UseItem"},

	{"Packages","Net","RE/LaserCape"},
	{"Net","RE/LaserCape"},
	{"RE/LaserCape"},
	{"Remotes","LaserCape"},
	{"LaserCape"},
}

local function getByChain(root, chain)
	local node = root
	for i = 1, #chain do
		node = node and node:FindFirstChild(chain[i])
		if not node then return nil end
	end
	return node
end

local function getClosestTargetHRP()
	local char = player.Character
	if not char then return nil end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return nil end

	local myPos = hrp.Position
	local closestHRP, best = nil, math.huge

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local thrp = p.Character:FindFirstChild("HumanoidRootPart")
			if thrp then
				local d = (thrp.Position - myPos).Magnitude
				if d < best then
					best = d
					closestHRP = thrp
				end
			end
		end
	end

	if best <= MAX_DISTANCE then
		return closestHRP
	end
end

local function fireRemotes(targetHRP)
	local args = { targetHRP.Position, targetHRP }
	for _, chain in ipairs(REMOTE_CHAINS) do
		local remote = getByChain(ReplicatedStorage, chain)
		if remote and remote.FireServer then
			local ok = pcall(function()
				remote:FireServer(unpack(args))
			end)
			if ok then return true end
		end
	end
	return false
end

local function executeAimbot()
	local now = tick()
	if now - lastFire < COOLDOWN then return end
	lastFire = now

	local targetHRP = getClosestTargetHRP()
	if not targetHRP then return end
	fireRemotes(targetHRP)
end

-- Inputs: F, clique do mouse, toque
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.F then
		executeAimbot()
	elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
		executeAimbot()
	elseif input.UserInputType == Enum.UserInputType.Touch then
		executeAimbot()
	end
end)

if UserInputService.TouchEnabled and UserInputService.TouchTap then
	UserInputService.TouchTap:Connect(function(_, processed)
		if not processed then executeAimbot() end
	end)
end
