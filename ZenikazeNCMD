-- Função para gerar ID único do brainrot
local function getBrainrotId(brainrot)
    return brainrot.name .. "|" .. brainrot.rarity .. "|" .. (brainrot.value or "")
end

-- Função para verificar mudanças
local function brainhotsChanged(currentBrainhots)
    if #currentBrainhots ~= #cache.lastBrainhots then
        return true
    end
    
    local currentIds = {}
    for _, brainrot in pairs(currentBrainhots) do
        currentIds[getBrainrotId(brainrot)] = true
    end
    
    local lastIds = {}
    for _, brainrot in pairs(cache.lastBrainhots) do
        lastIds[getBrainrotId(brainrot)] = true
    end
    
    for id, _ in pairs(currentIds) do
        if not lastIds[id] then
            return true
        end
    end
    
    for id, _ in pairs(lastIds) do
        if not currentIds[id] then
            return true
        end
    end
    
    return false
end

-- Função para exibir estatísticas
local function printStats()
    local stats = cache.sessionData
    debugLog("=== ESTATISTICAS DA SESSAO ===")
    debugLog(string.format("Servidores escaneados: %d", stats.serversScanned))
    debugLog(string.format("Secrets encontrados: %d", stats.secretsFound))
    debugLog(string.format("Conexoes Python: %d (Falhas: %d)", stats.pythonConnections, stats.failedConnections))
    debugLog(string.format("Status Python: %s", cache.pythonStatus))
end

-- Loop principal
task.spawn(function()
    debugLog("Scanner ativo (1M+ Range - Configuravel via Python)")
    
    while true do
        local highValueBrainhots = checkForHighValueBrainhots()
        
        if #highValueBrainhots > 0 then
            local currentTime = tick()
            
            if brainhotsChanged(highValueBrainhots) then
                debugLog(string.format("%d Secrets 1M+ detectados!", #highValueBrainhots))
                
                if currentTime - cache.lastNotificationTime >= getgenv().ZENIKAZE_CONFIG.cooldownTime then
                    local pythonSuccess = sendToPythonTerminal(highValueBrainhots, game.JobId)
                    
                    if pythonSuccess then
                        cache.lastNotificationTime = currentTime
                        cache.lastBrainhots = highValueBrainhots
                        debugLog("Dados enviados para Python AutoJoiner!")
                    else
                        debugLog("Falha ao enviar dados - tentara novamente no proximo scan", true)
                    end
                else
                    local timeLeft = getgenv().ZENIKAZE_CONFIG.cooldownTime - (currentTime - cache.lastNotificationTime)
                    debugLog(string.format("Cooldown ativo - %d segundos restantes", math.ceil(timeLeft)))
                    cache.lastBrainhots = highValueBrainhots
                end
            end
        else
            if #cache.lastBrainhots > 0 then
                cache.lastBrainhots = {}
                debugLog("Cache limpo - Nenhum Secret 1M+ encontrado")
            end
        end
        
        task.wait(getgenv().ZENIKAZE_CONFIG.scanInterval)
    end
end)

