local function updateESP()
    if not ESP_SETTINGS.Enabled then return end

    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    for object, espData in pairs(ESPObjects) do
        if not object or not object.Parent then
            removeESP(object)
            continue
        end

        pcall(function()
            local objectPos = nil

            if espData.type == "Player" then
                local hrp = object:FindFirstChild("HumanoidRootPart")
                objectPos = hrp and hrp.Position
            else
                objectPos = object.Position
            end

            if objectPos and espData.billboard then
                local distance = (myHRP.Position - objectPos).Magnitude

                if distance <= ESP_SETTINGS.MaxDistance then
                    espData.billboard.Enabled = true

                    local distanceLabel = espData.billboard:FindFirstChild("DistanceLabel", true)
                    if distanceLabel then
                        distanceLabel.Text = math.floor(distance) .. "m"
                    end
                else
                    espData.billboard.Enabled = false
                end
            end
        end)
    end
end

