-- Loop ESP principal
ActiveConnections.ESPLoop = task.spawn(function()
    while true do
        if ESP_SETTINGS.Enabled then
            updateESP()
            updateBaseESP() -- Atualizar Base ESP

            if ESP_SETTINGS.Players then
                scanForPlayers()
            end
            if ESP_SETTINGS.BrainhotsGods or ESP_SETTINGS.BrainhotsSecrets then
                scanForObjects()
            end
            if ESP_SETTINGS.BaseESP then
                scanForBases()
            end
        end
        task.wait(1) -- Atualização mais frequente para o timer
    end
end)

-- Event handlers
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        if ESP_SETTINGS.Players then
            task.wait(2)
            if character and character:FindFirstChild("HumanoidRootPart") then
                createESPBox(character, "Player", player.Name)
            end
        end
    end)
end)

Players.PlayerRemoving:Connect(function(player)
    if player.Character and ESPObjects[player.Character] then
        removeESP(player.Character)
    end
end)

