task.spawn(function()
    while true do
        pcall(function()
            if getgenv().ZK_AutoJoin then
                local rec = fetch_latest_any()
                if rec and rec.server and rec.server.jobId then
                    local key = (rec.__uid or "?") .. "|" .. (rec.__ts or "?")
                    local hv  = bestHighestValue(rec)

                    if statusLabel then
                        statusLabel.Text = string.format("Pronto • %s • %s",
                            (rec.server.jobId and shortJob(rec.server.jobId) or "?"),
                            (hv>=1e6 and string.format("%.0fM", hv/1e6) or tostring(hv))
                        )
                    end

                    if key ~= lastKey and rec.server.jobId ~= lastJobId and tick() >= cooldownUntil then
                        lastKey   = key
                        lastJobId = rec.server.jobId

                        local failed = false
                        local conn
                        pcall(function()
                            conn = TeleportService.TeleportInitFailed:Connect(function(plr)
                                if plr == LocalPlayer then failed = true end
                            end)
                        end)

                        pcall(function()
                            TeleportService:TeleportToPlaceInstance(
                                rec.server.placeId or game.PlaceId,
                                rec.server.jobId,
                                LocalPlayer
                            )
                        end)

                        task.delay(3, function() 
                            pcall(function()
                                if conn then conn:Disconnect() end 
                            end)
                        end)

                        task.delay(20, function()
                            pcall(function()
                                if not failed and rec.__uid and rec.__ts then
                                    fb_delete(string.format("/zenikaze/servers/%s/%s.json", rec.__uid, rec.__ts))
                                end
                            end)
                        end)

                        cooldownUntil = tick() + 8
                    end
                else
                    if statusLabel then
                        statusLabel.Text = "Aguardando registros… " .. (getConfiguredUserId() and ("Fonte: "..getConfiguredUserId()) or "Fonte: Global")
                    end
                end
            end
        end)
        task.wait(2.2)
    end
end)

