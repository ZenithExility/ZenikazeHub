-- Proteção avançada contra todos os tipos de kick
local function setupMaxAntiKick()
    -- 1. Proteger kick direto do player
    pcall(function()
        local oldKick = LocalPlayer.Kick
        LocalPlayer.Kick = function() end
        
        -- Hook no índice do player também
        local oldIndex = nil
        oldIndex = hookmetamethod(LocalPlayer, "__index", function(self, key)
            if key == "Kick" then
                return function() end
            end
            return oldIndex(self, key)
        end)
    end)
    
    -- 2. Proteger contra remote events suspeitos
    pcall(function()
        local mt = getrawmetatable(game)
        if mt then
            setreadonly(mt, false)
            local oldNamecall = mt.__namecall
            
            mt.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                local args = {...}
                
                if method == "FireServer" or method == "InvokeServer" then
                    local name = tostring(self):lower()
                    local script = tostring(getfenv(2).script):lower()
                    
                    -- Lista de palavras suspeitas
                    local suspiciousWords = {
                        "kick", "ban", "anti", "detect", "cheat", "exploit", 
                        "hack", "script", "admin", "mod", "security", "ac",
                        "anticheat", "punishment", "remove", "disconnect"
                    }
                    
                    for _, word in pairs(suspiciousWords) do
                        if name:find(word) or script:find(word) then
                            return -- Bloquear silenciosamente
                        end
                    end
                    
                    -- Verificar argumentos
                    for _, arg in pairs(args) do
                        if type(arg) == "string" then
                            local argLower = arg:lower()
                            for _, word in pairs(suspiciousWords) do
                                if argLower:find(word) then
                                    return -- Bloquear silenciosamente
                                end
                            end
                        end
                    end
                end
                
                if method == "Kick" or method == "kick" then
                    return -- Bloquear todos os kicks
                end
                
                return oldNamecall(self, ...)
            end)
            
            setreadonly(mt, true)
        end
    end)
    
    -- 3. Hook adicional para capturar outros métodos
    pcall(function()
        local oldHook = hookmetamethod(game, "__namecall", function(...)
            local method = getnamecallmethod()
            if method:lower():find("kick") then
                return
            end
            return oldHook(...)
        end)
    end)
    
    -- 4. Proteger contra TeleportService kicks
    pcall(function()
        local TeleportService = game:GetService("TeleportService")
        local oldTeleport = TeleportService.Teleport
        TeleportService.Teleport = function(self, placeId, player, ...)
            if player == LocalPlayer then
                -- Se for tentativa de kick via teleport, ignorar
                return
            end
            return oldTeleport(self, placeId, player, ...)
        end
    end)
end

-- Aplicar todas as proteções
setupMaxAntiKick()

