    if not hum or not root then stopFloat() return end

    local startY = root.Position.Y

    floatConn = RunService.Heartbeat:Connect(function()
        if not floatActive then return end
        pcall(function()
            if hum.Health <= 0 then stopFloat() return end

            hum:ChangeState(Enum.HumanoidStateType.Flying)
            local cam = workspace.CurrentCamera
            local look = cam and cam.CFrame.LookVector or Vector3.new(0,0,-1)
            look = Vector3.new(look.X,0,look.Z)
            if look.Magnitude > 0 then look = look.Unit else look = Vector3.new(0,0,-1) end

            local pos = root.Position
            local maxY = startY + FLOAT_RISE
            if pos.Y < maxY then
                local rise = math.min(FLOAT_SPEED, (maxY-pos.Y)*10)
                root.AssemblyLinearVelocity = look*FLOAT_SPEED + Vector3.new(0,rise,0)
            else
                root.AssemblyLinearVelocity = look*FLOAT_SPEED
            end
        end)
    end)

    hum.Died:Connect(function() stopFloat() end)
end

