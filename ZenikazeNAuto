local function logDebug(msg)
    if getgenv().ZENIKAZE_CONFIG.debugMode then
        print("[ZENIKAZE DEBUG] " .. tostring(msg))
    end
end

local function generateUserId()
    if getgenv().ZENIKAZE_CONFIG.userId == "" then
        local chars = "abcdefghijklmnopqrstuvwxyz0123456789"
        local id = {}
        for i = 1, 12 do
            local idx = math.random(1, #chars)
            table.insert(id, string.sub(chars, idx, idx))
        end
        getgenv().ZENIKAZE_CONFIG.userId = table.concat(id)
        print("[ZENIKAZE] Generated User ID: " .. getgenv().ZENIKAZE_CONFIG.userId)
    end
    return getgenv().ZENIKAZE_CONFIG.userId
end

local function isServerCrowded()
    local currentPlayers = #Players:GetPlayers()
    return currentPlayers >= 8 or currentPlayers > getgenv().ZENIKAZE_CONFIG.maxPlayersToJoin
end

-- =========================
-- EXTRAÇÃO DE VALORES
-- =========================
local function getBrainrotValue(object)
    if not object or not object.Parent then return 0 end
    local ok, val = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d:IsA("TextLabel") and d.Text then
                local t = d.Text

                local b = t:match("([%d%.]+)B/?[sS]?e?c?")
                if b and tonumber(b) then return tonumber(b) * 1e9 end

                local m = t:match("([%d%.]+)M/?[sS]?e?c?")
                if m and tonumber(m) then return tonumber(m) * 1e6 end

                local c = t:match("([%d,]+),000,000/?[sS]?e?c?")
                if c then
                    local n = tonumber(c:gsub(",", ""))
                    if n then return n * 1e6 end
                end

                local digits = t:match("([%d]+)/?[sS]?e?c?")
                if digits and #digits >= 7 then
                    local n = tonumber(digits)
                    if n and n >= 1e6 then return n end
                end

                local k = t:match("([%d%.]+)K/?[sS]?e?c?")
                if k and tonumber(k) then return tonumber(k) * 1e3 end
            end
        end
        return 0
    end)
    return ok and val or 0
end

local function isHighValueBrainrot(object, rarity)
    if not object or not object.Parent then return false end
    if rarity ~= "Secret" then return false end
    return getBrainrotValue(object) >= getgenv().ZENIKAZE_CONFIG.minSecretValue
end

local function getRarityFromObject(object)
    if not object or not object.Parent then return nil end
    local ok, r = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d.Name == "Rarity" and d:IsA("TextLabel") then
                return (d.Text or ""):gsub("%s+", "")
            end
            if d.Name == "DisplayName" and d:IsA("TextLabel") then
                for rar in (d.Text or ""):gmatch("%[([^%]]+)%]") do
                    return rar
                end
            end
        end
        return nil
    end)
    return ok and r or nil
end

local function getDisplayName(object)
    local ok, name = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d.Name == "DisplayName" and d:IsA("TextLabel") then
                return d.Text
            end
        end
        return object.Name
    end)
    return ok and name or (object.Name or "Brainrot")
end

local function formatValue(num)
    if num >= 1e9 then
        return string.format("%.1fB/sec", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.1fM/sec", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.1fK/sec", num / 1e3)
    else
        return string.format("%.0f/sec", num)
    end
end

local function getFormattedValue(object)
    return formatValue(getBrainrotValue(object))
end

-- =========================
-- HTTP (EXECUTOR FALLBACKS)
-- =========================
local function raw_request(opts)
    local req = (http_request)
        or (syn and syn.request)
        or request
        or (fluxus and fluxus.request)
        or (krnl_request)
        or (http and http.request)
        or nil

    if req then
        local ok, res = pcall(function() return req(opts) end)
        if ok and res and tonumber(res.StatusCode or 0) >= 200 and tonumber(res.StatusCode or 0) < 300 then
            return true, res.Body
        end
    end

    -- fallback HttpService
    local ok2, res2 = pcall(function()
        return HttpService:RequestAsync({
            Url = opts.Url,
            Method = opts.Method,
            Headers = opts.Headers,
            Body = opts.Body
        })
    end)
    if ok2 and res2 and res2.Success then
        return true, res2.Body
    end
    return false, nil
end

-- =========================
-- ENVIO PARA FIREBASE (FORMATO COMPATÍVEL)
-- =========================
local function sendToCloud(foundBrainhots, jobId)
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and game.PrivateServerId ~= "" then
        logDebug("Avoiding private server")
        return false
    end
    if isServerCrowded() then
        logDebug("Server is crowded")
        return false
    end
    if #foundBrainhots == 0 then
        logDebug("No brainhots to send")
        return false
    end

    local userId = generateUserId()
    local timestamp = os.time()

    -- Estrutura de dados COMPATÍVEL com Auto Joiner
    local data = {
        server = {
            jobId = jobId,
            placeId = game.PlaceId,
            playerCount = #Players:GetPlayers(),
            maxPlayers = Players.MaxPlayers,
            isPrivate = game.PrivateServerId ~= "",
            isCrowded = isServerCrowded()
        },
        secrets = {},
        statistics = {
            totalSecrets = #foundBrainhots,
            highestValue = 0
        },
        timestamp = timestamp,
        userId = userId
    }

    -- Preenche os secrets
    for _, info in ipairs(foundBrainhots) do
        local raw = getBrainrotValue(info.object) or 0
        if raw > data.statistics.highestValue then
            data.statistics.highestValue = raw
        end
        table.insert(data.secrets, {
            name = info.name,
            rarity = info.rarity,
            rawValue = raw,
            formattedValue = getFormattedValue(info.object)
        })
    end

    local jsonData = HttpService:JSONEncode(data)
    
    -- URL no formato que o Auto Joiner espera
    local url = string.format("%s/zenikaze/servers/%s/%s.json", 
        getgenv().ZENIKAZE_CONFIG.firebaseUrl, userId, tostring(timestamp))
    
    print("[ZENIKAZE] Sending data to: " .. url)
    print("[ZENIKAZE] Data preview: " .. jsonData:sub(1, 200) .. "...")

    local success, response = raw_request({
        Url = url,
        Method = "PUT",
        Headers = {["Content-Type"] = "application/json"},
        Body = jsonData
    })

    if success then
        cache.sessionData.cloudConnections = cache.sessionData.cloudConnections + 1
        print("[ZENIKAZE] ✅ Data sent successfully! Secrets: " .. #foundBrainhots .. " | Highest: " .. formatValue(data.statistics.highestValue))
        return true
    else
        cache.sessionData.failedConnections = cache.sessionData.failedConnections + 1
        print("[ZENIKAZE] ❌ Failed to send data")
        return false
    end
end

-- =========================
-- SCAN
-- =========================
local function checkForHighValueBrainhots()
    local found, totalScanned = {}, 0

    pcall(function()
        local Workspace = game:GetService("Workspace")
        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return end

        for _, plot in ipairs(plots:GetChildren()) do
            local isMyPlot = false
            pcall(function()
                local sign = plot:FindFirstChild("PlotSign")
                if sign then
                    local gui = sign:FindFirstChild("SurfaceGui")
                    if gui and gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("TextLabel") then
                        local txt = gui.Frame.TextLabel.Text or ""
                        if txt:find(Players.LocalPlayer.Name) then
                            isMyPlot = true
                        end
                    end
                end
            end)

            if not isMyPlot then
                for _, d in ipairs(plot:GetDescendants()) do
                    if (d:IsA("BasePart") or d:IsA("MeshPart")) and d.Parent then
                        totalScanned += 1
                        local rarity = getRarityFromObject(d)
                        if rarity == "Secret" and isHighValueBrainrot(d, rarity) then
                            table.insert(found, {
                                name  = getDisplayName(d),
                                rarity = rarity,
                                value  = getFormattedValue(d),
                                object = d
                            })
                        end
                    end
                end
            end
        end
    end)

    cache.sessionData.secretsFound = cache.sessionData.secretsFound + #found
    return found
end

