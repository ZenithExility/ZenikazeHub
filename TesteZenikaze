task.spawn(function()
    local lastScanTime = 0
    local SCAN_INTERVAL = 3  -- Escaneia apenas a cada 3 segundos

    while true do
        local currentTime = tick()

        pcall(function()
            if ESP_SETTINGS.Enabled and ESP_SETTINGS.Players then
                scanForPlayers()
            end

            -- Só escaneia objetos ocasionalmente para reduzir lag
            if currentTime - lastScanTime > SCAN_INTERVAL then
                if ESP_SETTINGS.Enabled and (ESP_SETTINGS.BrainhotsGods or ESP_SETTINGS.BrainhotsSecrets) then
                    scanForObjects()
                end
                lastScanTime = currentTime
            end

            updateESP()
        end)
        task.wait(1)  -- Reduzido de 2 para 1 segundo para melhor responsividade do ESP de players
    end
end)

