-- Função principal: enviar dados para a nuvem
local function sendToCloud(foundSecrets, jobId)
    if cache.connectionStatus ~= "CONNECTED" then
        cloudLog("Sem conexão com nuvem - tentando reconectar...", "WARNING")
        local connected, endpoint = testCloudConnection()
        if not connected then
            cloudLog("Falha ao conectar com servidor na nuvem!", "ERROR")
            return false
        end
        cloudLog("Reconectado ao servidor na nuvem!", "SUCCESS")
    end
    
    -- Montar dados para enviar
    local cloudData = {
        action = "NEW_SERVER_FOUND",
        timestamp = DateTime.now and DateTime.now():ToIsoDate() or os.date("%Y-%m-%dT%H:%M:%SZ"),
        
        -- Informações do cliente
        client_info = {
            session_id = cache.sessionId,
            name = getgenv().ZENIKAZE_CLOUD_CONFIG.clientName,
            version = getgenv().ZENIKAZE_CLOUD_CONFIG.version,
            roblox_user = player.Name,
            user_id = player.UserId,
            room_id = getgenv().ZENIKAZE_CLOUD_CONFIG.roomId
        },
        
        -- Informações do servidor
        server = {
            jobId = jobId,
            placeId = game.PlaceId,
            playerCount = #Players:GetPlayers(),
            maxPlayers = Players.MaxPlayers,
            joinLink = buildJoinLink(game.PlaceId, jobId)
        },
        
        -- Secrets encontrados
        secrets = {},
        
        -- Estatísticas da sessão
        statistics = {
            totalSecrets = #foundSecrets,
            highestValue = 0,
            scanTime = tick() - cache.lastScan,
            clientStats = {
                totalScans = cache.totalScans,
                serversSent = cache.serversSent,
                secretsFound = cache.secretsFound,
                sessionUptime = tick() - cache.sessionStart
            }
        }
    }
    
    -- Processar secrets
    for i = 1, #foundSecrets do
        local secretInfo = foundSecrets[i]
        local rawValue = secretInfo.rawValue or 0
        
        if rawValue > cloudData.statistics.highestValue then
            cloudData.statistics.highestValue = rawValue
        end
        
        table.insert(cloudData.secrets, {
            name = secretInfo.name,
            rarity = secretInfo.rarity,
            value = secretInfo.value,
            rawValue = rawValue,
            formattedValue = secretInfo.value
        })
    end
    
    -- Converter para JSON
    local jsonData
    local success, result = pcall(function()
        return HttpService:JSONEncode(cloudData)
    end)
    
    if not success then
        cloudLog("Erro ao preparar dados: " .. tostring(result), "ERROR")
        return false
    end
    
    jsonData = result
    
    -- Métodos de envio para a nuvem
    local cloudMethods = {
        function()
            if http_request then
                return http_request({
                    Url = getgenv().ZENIKAZE_CLOUD_CONFIG.cloudServer,
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json",
                        ["User-Agent"] = "Zenikaze-Cloud/" .. getgenv().ZENIKAZE_CLOUD_CONFIG.version,
                        ["X-Client-ID"] = cache.sessionId,
                        ["X-Room-ID"] = getgenv().ZENIKAZE_CLOUD_CONFIG.roomId
                    },
                    Body = jsonData,
                    Timeout = 20
                })
            end
            return false
        end,
        function()
            if request then
                return request({
                    Url = getgenv().ZENIKAZE_CLOUD_CONFIG.cloudServer,
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json",
                        ["User-Agent"] = "Zenikaze-Cloud"
                    },
                    Body = jsonData,
                    Timeout = 20
                })
            end
            return false
        end
    }
    
    -- Tentar enviar
    for methodIndex, method in ipairs(cloudMethods) do
        local success, response = pcall(method)
        
        if success and response and (response.StatusCode == 200 or response.Success) then
            cache.serversSent = cache.serversSent + 1
            cache.lastServerSent = jobId
            cache.connectionStatus = "CONNECTED"
            
            cloudLog(string.format("☁️ DADOS ENVIADOS! (%d secrets)", #foundSecrets), "CLOUD")
            
            -- Processar resposta da nuvem
            if response.Body then
                local responseSuccess, responseData = pcall(function()
                    return HttpService:JSONDecode(response.Body)
                end)
                
                if responseSuccess and responseData then
                    if responseData.status == "success" then
                        local approved = responseData.secrets_approved or 0
                        local total = responseData.secrets_total or 0
                        cloudLog(string.format("✅ Processado na nuvem: %d/%d secrets aprovados", approved, total), "SUCCESS")
                        
                        if responseData.room_id then
                            cache.roomConnected = responseData.room_id
                            cloudLog(string.format("🏠 Sala: %s", responseData.room_id), "INFO")
                        end
                        
                        if responseData.is_chilli then
                            cloudLog("🔥 CHILLI JOIN DETECTADO NA NUVEM! 🔥", "SUCCESS")
                        end
                        
                        if responseData.auto_join_available then
                            cloudLog("🎯 Auto-join disponível para admins conectados!", "SUCCESS")
                        end
                        
                        if responseData.admins_notified and responseData.admins_notified > 0 then
                            cloudLog(string.format("👥 %d admin(s) notificado(s)", responseData.admins_notified), "SUCCESS")
                        end
                        
                        if responseData.highest_value and responseData.highest_value > 0 then
                            cloudLog(string.format("💎 Maior valor: %s", formatValue(responseData.highest_value)), "SUCCESS")
                        end
                        
                    elseif responseData.status == "filtered" then
                        cloudLog("⚠️ Servidor rejeitado: não passou nos filtros da nuvem", "WARNING")
                    elseif responseData.status == "no_secrets" then
                        cloudLog("ℹ️ Nuvem: nenhum secret encontrado", "INFO")
                    else
                        cloudLog("Resposta da nuvem: " .. (responseData.message or "Processado"), "INFO")
                    end
                end
            end
            
            return true
        end
    end
    
    cache.connectionStatus = "OFFLINE"
    cloudLog("❌ Falha ao enviar para nuvem - Servidor offline?", "ERROR")
    return false
end

-- Scanner principal (otimizado para performance)
local function scanForSecrets()
    local found = {}
    local totalScanned = 0
    local totalSecrets = 0
    
    local success, error_msg = pcall(function()
        local workspace = game:GetService("Workspace")
        local plotsFolder = workspace:FindFirstChild("Plots")
        
        if not plotsFolder then 
            cloudLog("Pasta 'Plots' não encontrada", "WARNING")
            return 
        end
        
        local plots = plotsFolder:GetChildren()
        cloudLog(string.format("🔍 Escaneando %d plots...", #plots), "INFO")
        
        for plotIndex = 1, #plots do
            local plot = plots[plotIndex]
            local isMyPlot = false
            
            -- Verificar se é meu plot (otimizado)
            pcall(function()
                local plotSign = plot:FindFirstChild("PlotSign")
                if plotSign then
                    local surfaceGui = plotSign:FindFirstChild("SurfaceGui")
                    if surfaceGui then
                        local frame = surfaceGui:FindFirstChild("Frame")
                        if frame then
                            local textLabel = frame:FindFirstChild("TextLabel")
                            if textLabel and textLabel.Text and textLabel.Text:find(player.Name) then
                                isMyPlot = true
                            end
                        end
                    end
                end
            end)
            
            if not isMyPlot then
                local descendants = plot:GetDescendants()
                
                -- Limitar busca para performance (máximo 200 objetos por plot)
                local maxSearch = math.min(#descendants, 200)
                
                for i = 1, maxSearch do
                    local descendant = descendants[i]
                    
                    if (descendant.ClassName == "Part" or descendant.ClassName == "MeshPart") and descendant.Parent then
                        totalScanned = totalScanned + 1
                        
                        local rarity = getRarityFromObject(descendant)
                        
                        if rarity then
                            totalSecrets = totalSecrets + 1
                            local displayName = getDisplayName(descendant)
                            local brainrotValue = getBrainrotValue(descendant)
                            local formattedValue = formatValue(brainrotValue)
                            
                            -- Aplicar filtro local mínimo
                            if brainrotValue >= getgenv().ZENIKAZE_CLOUD_CONFIG.minSecretValue and rarity == "Secret" then
                                local secretData = {
                                    name = displayName,
                                    rarity = rarity,
                                    value = formattedValue,
                                    rawValue = brainrotValue,
                                    object = descendant
                                }
                                
                                table.insert(found, secretData)
                                
                                cloudLog(string.format("💎 Secret: %s [%s] - %s", displayName, rarity, formattedValue), "SERVER")
                            end
                        end
                    end
                end
            end
        end
    end)
    
    if not success then
        cloudLog("Erro durante scan: " .. tostring(error_msg), "ERROR")
    end
    
    cache.secretsFound = cache.secretsFound + #found
    
    cloudLog(string.format("📊 Scan: %d objetos, %d secrets totais, %d aprovados", totalScanned, totalSecrets, #found), "INFO")
    
    return found
end

-- Loop principal de scanning
local lastScanTime = 0
local isScanning = false

local function mainCloudLoop()
    if isScanning then return end
    
    local currentTime = tick()
    
    -- Cooldown entre scans
    if currentTime - lastScanTime < getgenv().ZENIKAZE_CLOUD_CONFIG.scanInterval then
        return
    end
    
    isScanning = true
    lastScanTime = currentTime
    cache.lastScan = currentTime
    cache.totalScans = cache.totalScans + 1
    
    local success = pcall(function()
        cloudLog("🔍 Iniciando scan automático...", "INFO")
        
        local foundSecrets = scanForSecrets()
        
        if #foundSecrets > 0 then
            cloudLog(string.format("🎯 SERVIDOR ENCONTRADO! %d secrets detectados", #foundSecrets), "SUCCESS")
            
            -- Enviar para a nuvem
            local sent = sendToCloud(foundSecrets, game.JobId)
            
            if sent then
                cloudLog("☁️ Dados enviados para a nuvem com sucesso!", "CLOUD")
            else
                cloudLog("❌ Falha ao enviar dados para a nuvem", "ERROR")
            end
        else
            cloudLog("😐 Servidor limpo - nenhum secret encontrado", "INFO")
        end
    end)
    
    if not success then
        cloudLog("Erro durante scan principal", "ERROR")
    end
    
    isScanning = false
end

