local function scanForObjects()
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return end

    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

    pcall(function()
        for _, plot in ipairs(plotsFolder:GetChildren()) do
            pcall(function()
                -- Otimização: pula se muito distante
                if myHRP then
                    local plotPos = plot:FindFirstChild("Main") and plot.Main.Position
                    if plotPos and (myHRP.Position - plotPos).Magnitude > 300 then
                        return
                    end
                end

                local isMyPlot = false
                local plotSign = plot:FindFirstChild("PlotSign")

                if plotSign and plotSign:FindFirstChild("SurfaceGui") then
                    pcall(function()
                        local text = plotSign.SurfaceGui.Frame.TextLabel.Text
                        if text:find(LocalPlayer.Name) then
                            isMyPlot = true
                        end
                    end)
                end

                if not isMyPlot then
                    -- Otimização: limita busca a partes principais apenas
                    local decorations = plot:FindFirstChild("Decorations")
                    if decorations then
                        for _, decorModel in ipairs(decorations:GetChildren()) do
                            for _, descendant in ipairs(decorModel:GetChildren()) do
                                pcall(function()
                                    if (descendant:IsA("BasePart") or descendant:IsA("MeshPart")) and not ESPObjects[descendant] then
                                        local rarity = getRarityFromObject(descendant)

                                        local shouldShow = false
                                        if rarity == "BrainrotGod" and ESP_SETTINGS.BrainhotsGods then
                                            shouldShow = true
                                        elseif rarity == "Secret" and ESP_SETTINGS.BrainhotsSecrets then
                                            shouldShow = true
                                        end

                                        if shouldShow then
                                            local displayName = nil
                                            for _, child in pairs(descendant:GetChildren()) do
                                                if child.Name == "DisplayName" and child:IsA("TextLabel") then
                                                    displayName = child.Text
                                                    break
                                                end
                                            end

                                            createESPBox(descendant, "Item", displayName or rarity, rarity)
                                        end
                                    end
                                end)
                            end
                        end
                    end
                end
            end)
        end
    end)
end

