local function createBaseTimeESP()
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return function() end end

    local lastUpdateTime = 0
    local UPDATE_INTERVAL = 2  -- Atualiza apenas a cada 2 segundos para reduzir lag

    local function findPlayerPlot()
        for _, plot in ipairs(plotsFolder:GetChildren()) do
            local yourBase = plot:FindFirstChild("YourBase", true)
            if yourBase and yourBase:IsA("BoolValue") and yourBase.Value then
                return plot.Name
            end
        end
        return nil
    end

    local function createESP(plot, mainPart)
        if BaseESPObjects[plot.Name] then
            BaseESPObjects[plot.Name]:Destroy()
        end

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "PlotESP_"..plot.Name
        billboard.Size = UDim2.new(0, 120, 0, 25)  -- Tamanho reduzido
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.Adornee = mainPart
        billboard.MaxDistance = 800  -- Distância reduzida para melhor performance
        billboard.Parent = plot

        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BackgroundTransparency = 0.8
        frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        frame.BorderSizePixel = 0

        local label = Instance.new("TextLabel")
        label.Name = "Label"
        label.Size = UDim2.new(1, -6, 1, -6)
        label.Position = UDim2.new(0, 3, 0, 3)
        label.BackgroundTransparency = 1
        label.TextScaled = true
        label.Font = Enum.Font.Gotham
        label.TextSize = 12  -- Tamanho de texto reduzido
        label.TextStrokeTransparency = 0.5
        label.TextStrokeColor3 = Color3.new(0, 0, 0)
        label.Parent = frame

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 4)  -- Cantos menores
        corner.Parent = frame

        frame.Parent = billboard
        BaseESPObjects[plot.Name] = billboard

        return BaseESPObjects[plot.Name]
    end

    local function updateBaseESP()
        local currentTime = tick()
        if currentTime - lastUpdateTime < UPDATE_INTERVAL then
            return  -- Pula atualização se não passou tempo suficiente
        end
        lastUpdateTime = currentTime

        if not ScriptStatus.BaseESP then return end

        pcall(function()
            local playerPlot = findPlayerPlot()

            -- Atualiza apenas plots visíveis próximos ao jogador
            local myChar = LocalPlayer.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

            for _, plot in ipairs(plotsFolder:GetChildren()) do
                pcall(function()
                    -- Verifica distância para otimização
                    if myHRP then
                        local plotPos = plot:FindFirstChild("Main") and plot.Main.Position
                        if plotPos and (myHRP.Position - plotPos).Magnitude > 500 then
                            -- Remove ESP se muito distante
                            if BaseESPObjects[plot.Name] then
                                BaseESPObjects[plot.Name]:Destroy()
                                BaseESPObjects[plot.Name] = nil
                            end
                            return
                        end
                    end

                    local purchases = plot:FindFirstChild("Purchases")
                    local plotBlock = purchases and purchases:FindFirstChild("PlotBlock")
                    local mainPart = plotBlock and plotBlock:FindFirstChild("Main")
                    local billboardGui = mainPart and mainPart:FindFirstChild("BillboardGui")
                    local timeLabel = billboardGui and billboardGui:FindFirstChild("RemainingTime")

                    if timeLabel and mainPart then
                        local billboard = BaseESPObjects[plot.Name] or createESP(plot, mainPart)
                        if billboard then
                            local frame = billboard:FindFirstChild("Frame")
                            local label = frame and frame:FindFirstChild("Label")
                            local isUnlocked = (timeLabel.Text == "0s")
                            if label then
                                label.Text = isUnlocked and "Unlocked" or timeLabel.Text
                                if plot.Name == playerPlot then
                                    label.TextColor3 = Color3.fromRGB(0, 255, 0)  -- Verde para sua base
                                elseif isUnlocked then
                                    label.TextColor3 = ZENIKAZE_COLOR  -- Cor da UI para desbloqueado
                                else
                                    label.TextColor3 = Color3.fromRGB(255, 100, 100)  -- Vermelho para bloqueado
                                end
                            end
                        end
                    elseif BaseESPObjects[plot.Name] then
                        BaseESPObjects[plot.Name]:Destroy()
                        BaseESPObjects[plot.Name] = nil
                    end
                end)
            end
        end)
    end

    return updateBaseESP
end

