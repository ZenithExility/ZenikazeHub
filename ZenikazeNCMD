-- SISTEMA PRINCIPAL DE SCAN E NOTIFICAÇÃO
local lastScanTime = 0
local isScanning = false

local function mainScanLoop()
    if isScanning then return end
    
    local currentTime = tick()
    
    -- Cooldown entre scans
    if currentTime - lastScanTime < getgenv().ZENIKAZE_CONFIG.scanInterval then
        return
    end
    
    isScanning = true
    lastScanTime = currentTime
    
    local success = pcall(function()
        local foundBrainhots = checkForHighValueBrainhots()
        
        -- Verificar se houve mudanças ou se é a primeira verificação
        if brainhotsChanged(foundBrainhots) or #cache.lastBrainhots == 0 then
            cache.lastBrainhots = foundBrainhots
            
            if #foundBrainhots > 0 then
                debugLog(string.format("SERVIDOR COM SECRETS! Encontrados: %d", #foundBrainhots))
                
                -- Enviar para sistema híbrido Python
                local hybridSent = sendToHybridSystem(foundBrainhots, game.JobId)
                
                -- Log dos secrets encontrados
                for i, brainrot in ipairs(foundBrainhots) do
                    debugLog(string.format("Secret %d: %s [%s] - %s", i, brainrot.name, brainrot.rarity, brainrot.value))
                end
                
                -- Atualizar timestamp da última notificação
                cache.lastNotificationTime = currentTime
                
                if hybridSent then
                    debugLog("Sistema Híbrido processou os dados - AutoJoin ativo!")
                else
                    debugLog("Falha na comunicação com Sistema Híbrido", true)
                end
            else
                -- Server limpo
                if cache.hybridSystemStatus ~= "OFFLINE" then
                    debugLog("Servidor limpo - nenhum secret 1M+ encontrado")
                end
            end
        end
    end)
    
    if not success then
        debugLog("Erro durante scan principal", true)
    end
    
    isScanning = false
end

