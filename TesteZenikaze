-- FPS Destroyer com Medusa's Head
local FPSDestroyer = {}
FPSDestroyer.running = false

local function findTool(toolName)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end
    return backpack:FindFirstChild(toolName) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(toolName))
end

local function equipTool(tool)
    if tool and tool:IsA("Tool") and LocalPlayer.Character then
        tool.Parent = LocalPlayer.Character
    end
end

local function unequipTool(tool)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if tool and tool:IsA("Tool") and backpack then
        tool.Parent = backpack
    end
end

function FPSDestroyer:Start()
    if FPSDestroyer.running then return end
    FPSDestroyer.running = true
    ScriptStatus.FPSDestroyer = true
    SavedSettings.FPSDestroyer = true
    SaveSystem.Save(SavedSettings)

    task.spawn(function()
        -- Remove accessories from everyone
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                removeAllAccessoriesFromCharacter()
            end
            player.CharacterAdded:Connect(function(char)
                char:WaitForChild("Humanoid")
                task.wait(1)
                removeAllAccessoriesFromCharacter()
            end)
        end

        -- Equip bat
        local bat = findTool("Bat")
        if bat then
            equipTool(bat)
        end

        -- Start medusa loop
        local medusa = findTool("Medusa's Head")
        if medusa then
            while FPSDestroyer.running do
                equipTool(medusa)
                task.wait(0.1)
                unequipTool(medusa)
                task.wait(0.35)
            end
        end
    end)
