local function getRarityFromObject(object)
    if not object or not object.Parent then 
        return nil 
    end

    local success, result = pcall(function()
        for _, descendant in pairs(object:GetDescendants()) do
            if descendant.Name == "Rarity" and descendant:IsA("TextLabel") then
                return descendant.Text:gsub("%s+", "")
            end

            if descendant.Name == "DisplayName" and descendant:IsA("TextLabel") then
                local displayText = descendant.Text
                for rarity, _ in pairs(raritySettings) do
                    if displayText:find(rarity) then
                        return rarity
                    end
                end
            end
        end

        if object:IsA("BasePart") and object.Color == Color3.fromRGB(180, 40, 180) then
            return "BrainrotGod"
        end

        return nil
    end)

    return success and result or nil
end

