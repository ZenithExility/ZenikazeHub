-- ZENIKAZE HU⚡️ CLOUD NOTIFIER - SECRETS 1M+
-- Envia para Firebase apenas servidores públicos, não lotados, e com Secret >= 1M.

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- =========================
-- Configurações principais
-- =========================
getgenv().ZENIKAZE_CONFIG = {
    -- SUBSTITUA COM SEU PROJETO FIREBASE
    firebaseUrl = "https://zenikaze-hub-default-rtdb.firebaseio.com",

    -- Configurações do sistema
    autoJoinEnabled = true,
    minSecretValue = 1000000,  -- 1M+
    scanInterval = 15,         -- segundos entre varreduras
    cooldownTime = 60,         -- segundos para reenviar mesmo server
    debugMode = false,

    -- Filtros de servidor
    maxPlayersToJoin = 7,      -- evita 8/8 (ou >= MaxPlayers)
    avoidPrivateServers = true,
    onlyPublicServers = true,

    -- ID único do usuário (gerado automaticamente)
    userId = ""
}

-- =========================
-- Cache persistente global
-- =========================
if not getgenv().ZenikazeHub_1M_Cache then
    getgenv().ZenikazeHub_1M_Cache = {
        lastBrainhots = {},
        lastNotificationTime = 0,
        serverJobId = "",
        sessionData = {
            serversScanned = 0,
            secretsFound = 0,
            cloudConnections = 0,
            failedConnections = 0
        }
    }
end

local cache = getgenv().ZenikazeHub_1M_Cache

-- =========================
-- Helpers
-- =========================
local function logDebug(msg)
    if getgenv().ZENIKAZE_CONFIG.debugMode then
        print("[ZENIKAZE-DBG] " .. tostring(msg))
    end
end

-- Gera ID único do usuário
local function generateUserId()
    if getgenv().ZENIKAZE_CONFIG.userId == "" then
        local chars = "abcdefghijklmnopqrstuvwxyz0123456789"
        local userId = ""
        math.randomseed(tick()*1e6 % 2^31)
        for i = 1, 12 do
            local randIndex = math.random(1, #chars)
            userId = userId .. string.sub(chars, randIndex, randIndex)
        end
        getgenv().ZENIKAZE_CONFIG.userId = userId
    end
    return getgenv().ZENIKAZE_CONFIG.userId
end

-- CORRIGIDO: privado se QUALQUER uma das flags indicar privado
local function isPrivateServer()
    local success, result = pcall(function()
        return (game.PrivateServerId ~= "") or (game.PrivateServerOwnerId ~= 0)
    end)
    return success and result
end

-- Lotado se >= MaxPlayers OU >=8 OU > limite configurado
local function isServerCrowded()
    local currentPlayers = #Players:GetPlayers()
    local maxPlayers = tonumber(Players and Players.MaxPlayers) or 8
    if currentPlayers >= maxPlayers then
        return true
    end
    if currentPlayers >= 8 then
        return true
    end
    if currentPlayers > getgenv().ZENIKAZE_CONFIG.maxPlayersToJoin then
        return true
    end
    return false
end

local function buildJoinLink(placeId, jobId)
    -- rejeita server privado/lotado
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and isPrivateServer() then
        return nil
    end
    if isServerCrowded() then
        return nil
    end
    -- link público
    return string.format(
        "https://www.roblox.com/games/%d/Brainrot-Simulator?gameInstanceId=%s",
        placeId,
        jobId
    )
end

-- =========================
-- Parsing de valores (1M+)
-- =========================
local function getBrainrotValue(object)
    if not object or not object.Parent then return 0 end

    local success, value = pcall(function()
        for _, descendant in ipairs(object:GetDescendants()) do
            if descendant:IsA("TextLabel") and descendant.Text then
                local text = descendant.Text

                -- "1.5B/sec"
                local bValue = text:match("([%d%.]+)%s*[bB]%s*/?%s*[sS]?[eE]?[cC]?")
                if bValue then
                    local num = tonumber(bValue)
                    if num then return num * 1000000000 end
                end

                -- "5.2M/sec", "10M"
                local mValue = text:match("([%d%.]+)%s*[mM]%s*/?%s*[sS]?[eE]?[cC]?")
                if mValue then
                    local num = tonumber(mValue)
                    if num then return num * 1000000 end
                end

                -- "5,000,000/sec", "12,000,000"
                local commaValue = text:match("([%d,]+)%s*/?%s*[sS]?[eE]?[cC]?")
                if commaValue and commaValue:find(",") then
                    local clean = commaValue:gsub(",", "")
                    local num = tonumber(clean)
                    if num and num >= 1000000 then
                        return num
                    end
                end

                -- número “seco” grande: 7+ dígitos
                local digits = text:match("(%d+)")
                if digits and #digits >= 7 then
                    local num = tonumber(digits)
                    if num and num >= 1000000 then
                        return num
                    end
                end

                -- "1000K/sec"
                local kValue = text:match("([%d%.]+)%s*[kK]%s*/?%s*[sS]?[eE]?[cC]?")
                if kValue then
                    local num = tonumber(kValue)
                    if num then return num * 1000 end
                end
            end
        end
        return 0
    end)

    return success and value or 0
end

local function isHighValueBrainrot(object, rarity)
    if not object or not object.Parent then return false end
    if rarity ~= "Secret" then return false end
    local brainrotValue = getBrainrotValue(object)
    return brainrotValue >= getgenv().ZENIKAZE_CONFIG.minSecretValue
end

local function getRarityFromObject(object)
    if not object or not object.Parent then return nil end

    local success, result = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d.Name == "Rarity" and d:IsA("TextLabel") then
                local rarityText = (d.Text or ""):gsub("%s+", "")
                return rarityText
            end
            if d.Name == "DisplayName" and d:IsA("TextLabel") then
                local displayText = d.Text or ""
                local tag = displayText:match("%[([^%]]+)%]")
                if tag then return tag end
            end
        end
        -- fallback por cor (exemplo genérico)
        if object:IsA("BasePart") then
            local color = object.Color
            if color == Color3.fromRGB(100, 100, 100) then
                return "Secret"
            end
        end
        return nil
    end)

    return success and result or nil
end

local function getDisplayName(object)
    local success, result = pcall(function()
        for _, child in ipairs(object:GetDescendants()) do
            if child.Name == "DisplayName" and child:IsA("TextLabel") then
                return child.Text
            end
        end
        return object.Name
    end)
    return success and result or (object.Name or "Brainrot")
end

local function getFormattedValue(object)
    local v = getBrainrotValue(object)
    if v >= 1000000000 then
        return string.format("%.1fB/sec", v/1000000000)
    elseif v >= 1000000 then
        return string.format("%.1fM/sec", v/1000000)
    elseif v >= 1000 then
        return string.format("%.1fK/sec", v/1000)
    else
        return string.format("%.0f/sec", v)
    end
end

-- =========================
-- Envio para Firebase
-- =========================
local function sendToCloud(foundBrainhots, jobId)
    -- bloquear privados/lotados de cara
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and isPrivateServer() then
        logDebug("Bloqueado: servidor privado")
        return false
    end
    if isServerCrowded() then
        logDebug("Bloqueado: servidor lotado")
        return false
    end
    if #foundBrainhots == 0 then return false end

    local userId = generateUserId()
    local timestamp = tostring(os.time())

    local joinLink = nil
    if getgenv().ZENIKAZE_CONFIG.onlyPublicServers then
        joinLink = buildJoinLink(game.PlaceId, jobId)
    end
    if not joinLink then
        logDebug("Sem joinLink válido (provável privado/lotado)")
        return false
    end

    local serverData = {
        userId = userId,
        timestamp = DateTime.now():ToIsoDate(),
        server = {
            jobId = jobId,
            placeId = game.PlaceId,
            playerCount = #Players:GetPlayers(),
            maxPlayers = Players.MaxPlayers,
            joinLink = joinLink,
            isPrivate = isPrivateServer(),
            isCrowded = isServerCrowded()
        },
        secrets = {},
        statistics = {
            totalSecrets = #foundBrainhots,
            highestValue = 0,
            sessionData = cache.sessionData
        },
        client_source = "roblox_lua_script",
        status = "active"
    }

    for _, info in ipairs(foundBrainhots) do
        local rawValue = getBrainrotValue(info.object) or 0
        if rawValue > serverData.statistics.highestValue then
            serverData.statistics.highestValue = rawValue
        end
        table.insert(serverData.secrets, {
            name = info.name,
            rarity = info.rarity,
            value = info.value,
            rawValue = rawValue,
            formattedValue = getFormattedValue(info.object)
        })
    end

    local jsonData = HttpService:JSONEncode(serverData)

    local firebaseEndpoint = string.format("%s/zenikaze/servers/%s/%s.json",
        getgenv().ZENIKAZE_CONFIG.firebaseUrl, userId, timestamp)
    local userEndpoint = string.format("%s/zenikaze/users/%s.json",
        getgenv().ZENIKAZE_CONFIG.firebaseUrl, userId)

    local userData = {
        lastActive = DateTime.now():ToIsoDate(),
        totalServers = cache.sessionData.serversScanned,
        totalSecrets = cache.sessionData.secretsFound,
        highestValue = serverData.statistics.highestValue,
        playerName = player and player.Name or "Player"
    }

    local function do_req(fn)
        local ok, resp = pcall(fn)
        return ok and resp
    end

    local methods = {
        function()
            if http_request then
                local s = http_request({
                    Url = firebaseEndpoint, Method = "PUT",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = jsonData
                })
                local u = http_request({
                    Url = userEndpoint, Method = "PATCH",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(userData)
                })
                return s and u
            end
            return false
        end,
        function()
            if request then
                local s = request({
                    Url = firebaseEndpoint, Method = "PUT",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = jsonData
                })
                local u = request({
                    Url = userEndpoint, Method = "PATCH",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(userData)
                })
                return s and u
            end
            return false
        end,
        function()
            if syn and syn.request then
                local s = syn.request({
                    Url = firebaseEndpoint, Method = "PUT",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = jsonData
                })
                local u = syn.request({
                    Url = userEndpoint, Method = "PATCH",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(userData)
                })
                return s and u
            end
            return false
        end
    }

    local cloudSuccess = false
    for _, m in ipairs(methods) do
        if do_req(m) then
            cloudSuccess = true
            cache.sessionData.cloudConnections = cache.sessionData.cloudConnections + 1
            break
        end
    end
    if not cloudSuccess then
        cache.sessionData.failedConnections = cache.sessionData.failedConnections + 1
    end

    return cloudSuccess
end

-- =========================
-- Scanner
-- =========================
local function getBrainrotId(br)
    return (br.name or "?") .. "|" .. (br.rarity or "?") .. "|" .. (br.value or "")
end

local function brainhotsChanged(current)
    if #current ~= #cache.lastBrainhots then return true end
    local curIds, lastIds = {}, {}
    for _, b in ipairs(current) do curIds[getBrainrotId(b)] = true end
    for _, b in ipairs(cache.lastBrainhots) do lastIds[getBrainrotId(b)] = true end
    for id,_ in pairs(curIds) do if not lastIds[id] then return true end end
    for id,_ in pairs(lastIds) do if not curIds[id] then return true end end
    return false
end

local function checkForHighValueBrainhots()
    local found, totalScanned = {}, 0
    local ok = pcall(function()
        local workspace = game:GetService("Workspace")
        local plotsFolder = workspace:FindFirstChild("Plots")
        if not plotsFolder then return end

        for _, plot in ipairs(plotsFolder:GetChildren()) do
            local isMyPlot = false
            pcall(function()
                local ps = plot:FindFirstChild("PlotSign")
                if ps and ps:FindFirstChild("SurfaceGui") then
                    local t = ps.SurfaceGui.Frame.TextLabel.Text
                    if t and player and t:find(player.Name) then
                        isMyPlot = true
                    end
                end
            end)
            if not isMyPlot then
                for _, d in ipairs(plot:GetDescendants()) do
                    if (d:IsA("BasePart") or d:IsA("MeshPart")) and d.Parent then
                        totalScanned += 1
                        local rarity = getRarityFromObject(d)
                        if rarity == "Secret" and isHighValueBrainrot(d, rarity) then
                            local displayName = getDisplayName(d)
                            local formattedValue = getFormattedValue(d)
                            table.insert(found, {
                                name = displayName,
                                rarity = rarity,
                                value = formattedValue,
                                object = d
                            })
                        end
                    end
                end
            end
        end
    end)

    cache.sessionData.secretsFound = cache.sessionData.secretsFound + #found
    return found
end

-- Detectar mudança de servidor
if cache.serverJobId ~= game.JobId then
    cache.serverJobId = game.JobId
    cache.lastBrainhots = {}
    cache.lastNotificationTime = 0
    cache.sessionData.serversScanned = cache.sessionData.serversScanned + 1
end

-- =========================
-- Loop principal
-- =========================
task.spawn(function()
    while true do
        local highValue = checkForHighValueBrainhots()

        if #highValue > 0 then
            local now = tick()
            if brainhotsChanged(highValue) then
                if now - cache.lastNotificationTime >= getgenv().ZENIKAZE_CONFIG.cooldownTime then
                    -- Só envia se link público válido (a própria sendToCloud bloqueia privado/lotado)
                    local ok = sendToCloud(highValue, game.JobId)
                    if ok then
                        cache.lastNotificationTime = now
                        cache.lastBrainhots = highValue
                        logDebug("Dados enviados à nuvem (1M+).")
                    else
                        logDebug("Envio bloqueado/sem sucesso.")
                    end
                else
                    cache.lastBrainhots = highValue
                    logDebug("Cooldown em curso; cache atualizado.")
                end
            else
                logDebug("Sem mudanças nos Secrets; nada enviado.")
            end
        else
            if #cache.lastBrainhots > 0 then
                cache.lastBrainhots = {}
                logDebug("Nenhum Secret 1M+ encontrado; limpando cache local.")
            end
        end

        task.wait(getgenv().ZENIKAZE_CONFIG.scanInterval)
    end
end)

-- Fim: Zenikaze Hub Cloud Scanner (1M+)
