local function raw_request(opts)
    local req = (http_request)
        or (syn and syn.request)
        or request
        or (fluxus and fluxus.request)
        or (krnl_request)
        or (http and http.request)
        or nil

    if req then
        local ok, res = pcall(function() return req(opts) end)
        if ok and res and tonumber(res.StatusCode or 0) >= 200 and tonumber(res.StatusCode or 0) < 300 then
            return true, res.Body
        end
    end

    local ok2, res2 = pcall(function()
        return HttpService:RequestAsync({
            Url = opts.Url,
            Method = opts.Method,
            Headers = opts.Headers,
            Body = opts.Body
        })
    end)
    if ok2 and res2 and res2.Success then
        return true, res2.Body
    end
    return false, nil
end

local function fb_get(path)
    return raw_request({
        Url = BASE .. path,
        Method = "GET",
        Headers = {["Content-Type"]="application/json"},
        Body = nil
    })
end

local function fb_delete(path)
    return raw_request({
        Url = BASE .. path,
        Method = "DELETE",
        Headers = {["Content-Type"]="application/json"},
        Body = nil
    })
end

local function getConfiguredUserId()
    if getgenv().ZENIKAZE_CONFIG and type(getgenv().ZENIKAZE_CONFIG.userId)=="string" and getgenv().ZENIKAZE_CONFIG.userId~="" then
        return getgenv().ZENIKAZE_CONFIG.userId
    end
    if type(getgenv().ZK_UserId)=="string" and getgenv().ZK_UserId~="" then
        return getgenv().ZK_UserId
    end
    return nil
end

local function toNumber(token)
    if type(token) ~= "string" then return nil end
    local raw = token:gsub(",", ""):gsub("%s+/+%s[sS][eE]?[cC]", ""):gsub("%s+", "")
    local num, suf = raw:match("^([%d%.]+)%s([kKmMbB]?)$")
    if not num then return nil end
    local n = tonumber(num); if not n then return nil end
    if suf=="k" or suf=="K" then n = n*1e3
    elseif suf=="m" or suf=="M" then n = n*1e6
    elseif suf=="b" or suf=="B" then n = n*1e9 end
    return n
end

local function bestHighestValue(rec)
    local hv = 0
    if rec.statistics and rec.statistics.highestValue and type(rec.statistics.highestValue) == "number" then
        hv = rec.statistics.highestValue
    end
    if hv == 0 and type(rec.secrets)=="table" then
        for _,s in ipairs(rec.secrets) do
            if s and s.rawValue and type(s.rawValue)=="number" then
                if s.rawValue > hv then hv = s.rawValue end
            elseif s and s.formattedValue and type(s.formattedValue)=="string" then
                local n = toNumber(s.formattedValue)
                if n and n > hv then hv = n end
            end
        end
    end
    return hv
end

local function shortJob(j)
    if not j or #j<8 then return tostring(j or "?") end
    return j:sub(1,4).."…" .. j:sub(-3)
end

local function pick_latest_from_bucket(bucket)
    local bestTs, bestRec
    for ts, rec in pairs(bucket) do
        repeat
            local tnum = tonumber(ts) or 0
            if not rec or not rec.server or not rec.server.jobId then break end
            if rec.server.placeId and rec.server.placeId ~= game.PlaceId then break end
            if getgenv().ZK_MaxAge and getgenv().ZK_MaxAge > 0 then
                local age = os.time() - tnum
                if age > getgenv().ZK_MaxAge then break end
            end
            if rec.server.isCrowded == true then break end
            if rec.server.isPrivate == true then break end
            local hv = bestHighestValue(rec)
            if hv < getgenv().ZK_MinValue then break end
            if hv > getgenv().ZK_MaxValue then break end
            if not bestTs or tnum > bestTs then
                bestTs, bestRec = tnum, rec
            end
        until true
    end
    if bestRec then
        bestRec.__ts = tostring(bestTs)
    end
    return bestRec
end

local function fetch_latest_any()
    local uid = getConfiguredUserId()
    if uid then
        local ok, body = fb_get(string.format("/zenikaze/servers/%s.json", uid))
        if ok and body and body ~= "null" then
            local ok2, bucket = pcall(function() return HttpService:JSONDecode(body) end)
            if ok2 and type(bucket)=="table" then
                local rec = pick_latest_from_bucket(bucket)
                if rec then 
                    rec.__uid = uid
                    return rec 
                end
            end
        end
    end

    local ok, body = fb_get("/zenikaze/servers.json")
    if not ok or not body or body=="null" then return nil end

    local ok2, top = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok2 or type(top)~="table" then return nil end

    local bestTs, bestRec, bestUid
    for uid2, bucket in pairs(top) do
        if type(bucket)=="table" then
            local rec = pick_latest_from_bucket(bucket)
            if rec then
                local tnum = tonumber(rec.__ts) or 0
                if not bestTs or tnum > bestTs then
                    bestTs, bestRec, bestUid = tnum, rec, uid2
                end
            end
        end
    end

    if bestRec then bestRec.__uid = bestUid end
    return bestRec
end

