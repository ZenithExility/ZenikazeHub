    local function clampToScreen(x,y,w,h)
        local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920,1080)
        local nx = math.clamp(x, 0, vp.X - w)
        local ny = math.clamp(y, 0, vp.Y - h)
