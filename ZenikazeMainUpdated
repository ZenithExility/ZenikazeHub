local function getBaseTimeRemaining(basePart)
    -- Sistema baseado no script EcstacyV2 - cada base tem timer individual
    local plotName = nil

    -- Encontrar o plot que contém esta base
    for _, plot in pairs(Workspace:FindFirstChild("Plots") and Workspace.Plots:GetChildren() or {}) do
        if plot:IsDescendantOf(plot) or basePart:IsDescendantOf(plot) then
            plotName = plot.Name
            break
        end
    end

    if plotName then
        -- Tentar encontrar o timer real do jogo (como no EcstacyV2)
        local success, timeText = pcall(function()
            local plot = Workspace.Plots[plotName]
            local timeLabel = plot:FindFirstChild("Purchases", true) and 
                             plot.Purchases:FindFirstChild("PlotBlock", true) and
                             plot.Purchases.PlotBlock.Main:FindFirstChild("BillboardGui", true) and
                             plot.Purchases.PlotBlock.Main.BillboardGui:FindFirstChild("RemainingTime", true)

            if timeLabel then
                return timeLabel.Text
            end
        end)

        if success and timeText then
            -- Converter texto do timer (ex: "2m 30s") para segundos
            local minutes = tonumber(timeText:match("(%d+)m")) or 0
            local seconds = tonumber(timeText:match("(%d+)s")) or 0
            return minutes * 60 + seconds
        end
    end

    -- Fallback: sistema individual por posição
    local baseId = tostring(basePart.Position.X + basePart.Position.Z)
    local hash = 0
    for i = 1, #baseId do
        hash = hash + string.byte(baseId, i)
    end

    local currentTime = tick()
    local baseInterval = 300 -- 5 minutos
    local offset = (hash % 100) * 3
    local adjustedTime = currentTime + offset
    local timeInCycle = adjustedTime % baseInterval
    local timeRemaining = baseInterval - timeInCycle

    return timeRemaining
end

local function formatTime(seconds)
    if seconds <= 0 then
        return "UNLOCKED"
    end

    local minutes = math.floor(seconds / 60)
    local remainingSeconds = math.floor(seconds % 60)
    return string.format("%02d:%02d", minutes, remainingSeconds)
end

