local function removeESP(object)
    local espData = ESPObjects[object]
    if espData then
        pcall(function()
            if espData.billboard then espData.billboard:Destroy() end
            if espData.highlight then espData.highlight:Destroy() end
        end)
        ESPObjects[object] = nil
    end
end

local function updateESP()
    if not ESP_SETTINGS.Enabled then return end
    
    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    
    for object, espData in pairs(ESPObjects) do
        if not object or not object.Parent then
            removeESP(object)
            continue
        end
        
        pcall(function()
            local objectPos = nil
            
            if espData.type == "Player" then
                local hrp = object:FindFirstChild("HumanoidRootPart")
                objectPos = hrp and hrp.Position
            else
                objectPos = object.Position
            end
            
            if objectPos and espData.billboard then
                local distance = (myHRP.Position - objectPos).Magnitude
                
                if distance <= ESP_SETTINGS.MaxDistance then
                    espData.billboard.Enabled = true
                    
                    local distanceLabel = espData.billboard:FindFirstChild("DistanceLabel", true)
                    if distanceLabel then
                        distanceLabel.Text = math.floor(distance) .. "m"
                    end
                else
                    espData.billboard.Enabled = false
                end
            end
        end)
    end
end

local function scanForPlayers()
    if not ESP_SETTINGS.Players then return end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            if not ESPObjects[player.Character] then
                createESPBox(player.Character, "Player", player.Name)
            end
        end
    end
end

local function scanForObjects()
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return end
    
    pcall(function()
        for _, plot in pairs(plotsFolder:GetChildren()) do
            pcall(function()
                local isMyPlot = false
                local plotSign = plot:FindFirstChild("PlotSign")
                
                if plotSign and plotSign:FindFirstChild("SurfaceGui") then
                    pcall(function()
                        local text = plotSign.SurfaceGui.Frame.TextLabel.Text
                        if text:find(LocalPlayer.Name) then
                            isMyPlot = true
                        end
                    end)
                end
                
                if not isMyPlot then
                    for _, descendant in pairs(plot:GetDescendants()) do
                        pcall(function()
                            if (descendant:IsA("BasePart") or descendant:IsA("MeshPart")) and not ESPObjects[descendant] then
                                local rarity = getRarityFromObject(descendant)
                                
                                local shouldShow = false
                                if rarity == "BrainrotGod" and ESP_SETTINGS.BrainhotsGods then
                                    shouldShow = true
                                elseif rarity == "Secret" and ESP_SETTINGS.BrainhotsSecrets then
                                    shouldShow = true
                                end
                                
                                if shouldShow then
                                    local displayName = nil
                                    for _, child in pairs(descendant:GetDescendants()) do
                                        if child.Name == "DisplayName" and child:IsA("TextLabel") then
                                            displayName = child.Text
                                            break
                                        end
                                    end
                                    
                                    createESPBox(descendant, "Item", displayName or rarity, rarity)
                                end
                            end
                        end)
                    end
                end
            end)
        end
    end)
end

