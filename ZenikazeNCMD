-- Função para monitorar conexão com Python
local function monitorPythonConnection()
    while true do
        task.wait(120) -- Verificar a cada 2 minutos
        
        -- Tentar ping no servidor Python
        local pingSuccess = false
        pcall(function()
            if http_request then
                local response = http_request({
                    Url = getgenv().ZENIKAZE_CONFIG.pythonEndpoint .. "/ping",
                    Method = "GET",
                    Headers = {
                        ["X-Zenikaze-Auth"] = "zenikaze_autojoiner_v1"
                    }
                })
                if response and response.StatusCode == 200 then
                    pingSuccess = true
                end
            end
        end)
        
        if pingSuccess then
            if cache.pythonStatus ~= "CONNECTED" then
                cache.pythonStatus = "CONNECTED"
                debugLog("Conexao com Python AutoJoiner restabelecida!")
            end
        else
            if cache.pythonStatus == "CONNECTED" then
                cache.pythonStatus = "OFFLINE"
                debugLog("Conexao com Python AutoJoiner perdida - verificando...", true)
            end
        end
    end
end

-- Iniciar monitor de conexão
