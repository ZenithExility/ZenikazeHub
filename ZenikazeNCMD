local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- =========================
-- CONFIG
-- =========================
getgenv().ZENIKAZE_CONFIG = {
    firebaseUrl = "https://zenikaze-hub-default-rtdb.firebaseio.com",

    autoJoinEnabled = true,
    minSecretValue = 1000000,     -- 1M+
    scanInterval   = 15,          -- seg
    cooldownTime   = 60,          -- seg entre envios iguais

    debugMode = false,

    -- Filtros de servidor
    maxPlayersToJoin   = 7,       -- rejeita 8+
    avoidPrivateServers = true,   -- no cliente não checamos PrivateServerId (sem spam)
    onlyPublicServers   = true,

    userId = ""
}

-- =========================
-- CACHE GLOBAL PERSISTENTE
-- =========================
if not getgenv().ZenikazeHub_1M_Cache then
    getgenv().ZenikazeHub_1M_Cache = {
        lastBrainhots = {},
        lastNotificationTime = 0,
        serverJobId = "",
        sessionData = {
            serversScanned = 0,
            secretsFound = 0,
            cloudConnections = 0,
            failedConnections = 0
        }
    }
end

local cache = getgenv().ZenikazeHub_1M_Cache
math.randomseed(tick() % 1 * 1e7)

-- =========================
-- UTILS
-- =========================
local function logDebug(msg)
    if getgenv().ZENIKAZE_CONFIG.debugMode then
        print("[ZENIKAZE DEBUG] " .. tostring(msg))
    end
end

local function isoNow()
    -- ISO-8601 UTC compatível com todos executores
    return os.date("!%Y-%m-%dT%H:%M:%SZ")
end

local function generateUserId()
    if getgenv().ZENIKAZE_CONFIG.userId == "" then
        local chars = "abcdefghijklmnopqrstuvwxyz0123456789"
        local id = {}
        for i = 1, 12 do
            local idx = math.random(1, #chars)
            table.insert(id, string.sub(chars, idx, idx))
        end
        getgenv().ZENIKAZE_CONFIG.userId = table.concat(id)
    end
    return getgenv().ZENIKAZE_CONFIG.userId
end

-- No cliente NÃO checamos PrivateServerId para evitar spam de aviso
local function isPrivateServer()
    if RunService:IsServer() then
        -- Se algum dia for usado no servidor, pode checar de fato aqui.
        return false
    end
    return false
end

local function isServerCrowded()
    local currentPlayers = #Players:GetPlayers()
    return currentPlayers >= 8 or currentPlayers > getgenv().ZENIKAZE_CONFIG.maxPlayersToJoin
end

local function buildJoinLink(placeId, jobId)
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and isPrivateServer() then
        return nil
    end
    if isServerCrowded() then
        return nil
    end
    return string.format("https://www.roblox.com/games/%d/Brainrot-Simulator?gameInstanceId=%s", placeId, jobId)
end

-- =========================
-- EXTRAÇÃO DE VALORES
-- =========================
local function getBrainrotValue(object)
    if not object or not object.Parent then return 0 end
    local ok, val = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d:IsA("TextLabel") and d.Text then
                local t = d.Text

                local b = t:match("([%d%.]+)B/?[sS]?e?c?")
                if b and tonumber(b) then return tonumber(b) * 1e9 end

                local m = t:match("([%d%.]+)M/?[sS]?e?c?")
                if m and tonumber(m) then return tonumber(m) * 1e6 end

                local c = t:match("([%d,]+),000,000/?[sS]?e?c?")
                if c then
                    local n = tonumber(c:gsub(",", ""))
                    if n then return n * 1e6 end
                end

                local digits = t:match("([%d]+)/?[sS]?e?c?") -- >= 7 dígitos => 1M+
                if digits and #digits >= 7 then
                    local n = tonumber(digits)
                    if n and n >= 1e6 then return n end
                end

                local k = t:match("([%d%.]+)K/?[sS]?e?c?")
                if k and tonumber(k) then return tonumber(k) * 1e3 end
            end
        end
        return 0
    end)
    return ok and val or 0
end

local function isHighValueBrainrot(object, rarity)
    if not object or not object.Parent then return false end
    if rarity ~= "Secret" then return false end
    return getBrainrotValue(object) >= getgenv().ZENIKAZE_CONFIG.minSecretValue
end

local function getRarityFromObject(object)
    if not object or not object.Parent then return nil end
    local ok, r = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d.Name == "Rarity" and d:IsA("TextLabel") then
                return (d.Text or ""):gsub("%s+", "")
            end
            if d.Name == "DisplayName" and d:IsA("TextLabel") then
                for rar in (d.Text or ""):gmatch("%[([^%]]+)%]") do
                    return rar
                end
            end
        end
        return nil
    end)
    return ok and r or nil
end

local function getDisplayName(object)
    local ok, name = pcall(function()
        for _, d in ipairs(object:GetDescendants()) do
            if d.Name == "DisplayName" and d:IsA("TextLabel") then
                return d.Text
            end
        end
        return object.Name
    end)
    return ok and name or (object.Name or "Brainrot")
end

local function formatValue(num)
    if num >= 1e9 then
        return string.format("%.1fB/sec", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.1fM/sec", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.1fK/sec", num / 1e3)
    else
        return string.format("%.0f/sec", num)
    end
end

local function getFormattedValue(object)
    return formatValue(getBrainrotValue(object))
end

-- =========================
-- HTTP (EXECUTOR FALLBACKS)
-- =========================
local function getHttp()
    return (http_request)
        or (syn and syn.request)
        or request
        or (fluxus and fluxus.request)
        or (krnl_request)
        or (http and http.request)
        or nil
end

-- =========================
-- ENVIO PARA FIREBASE
-- =========================
local function sendToCloud(foundBrainhots, jobId)
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and isPrivateServer() then
        return false
    end
    if isServerCrowded() then
        return false
    end
    if #foundBrainhots == 0 then
        return false
    end

    local userId = generateUserId()
    local tsIso = isoNow()

    local joinLink = nil
    if getgenv().ZENIKAZE_CONFIG.onlyPublicServers then
        joinLink = buildJoinLink(game.PlaceId, jobId)
    end
    if not joinLink then
        return false
    end

    local data = {
        userId = userId,
        timestamp = tsIso,
        server = {
            jobId = jobId,
            placeId = game.PlaceId,
            playerCount = #Players:GetPlayers(),
            maxPlayers = Players.MaxPlayers,
            joinLink = joinLink,
            isPrivate = false, -- não checado no cliente
            isCrowded = isServerCrowded()
        },
        secrets = {},
        statistics = {
            totalSecrets = #foundBrainhots,
            highestValue = 0,
            sessionData = cache.sessionData
        },
        client_source = "roblox_lua_script",
        status = "active"
    }

    for _, info in ipairs(foundBrainhots) do
        local raw = getBrainrotValue(info.object) or 0
        if raw > data.statistics.highestValue then
            data.statistics.highestValue = raw
        end
        table.insert(data.secrets, {
            name = info.name,
            rarity = info.rarity,
            value = info.value,
            rawValue = raw,
            formattedValue = getFormattedValue(info.object)
        })
    end

    local jsonData = HttpService:JSONEncode(data)

    local base = getgenv().ZENIKAZE_CONFIG.firebaseUrl
    local serverUrl = string.format("%s/zenikaze/servers/%s/%s.json", base, userId, tostring(os.time()))
    local userUrl   = string.format("%s/zenikaze/users/%s.json",   base, userId)

    local userData = {
        lastActive   = tsIso,
        totalServers = cache.sessionData.serversScanned,
        totalSecrets = cache.sessionData.secretsFound,
        highestValue = data.statistics.highestValue,
        playerName   = player and player.Name or "Unknown"
    }

    local http = getHttp()
    if not http then
        -- Sem HTTP raw no executor
        cache.sessionData.failedConnections += 1
        return false
    end

    local ok1, resp1 = pcall(function()
        return http({
            Url = serverUrl,
            Method = "PUT",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
    end)

    local ok2, resp2 = pcall(function()
        return http({
            Url = userUrl,
            Method = "PATCH",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(userData)
        })
    end)

    local success = ok1 and resp1 and ok2 and resp2
    if success then
        cache.sessionData.cloudConnections = cache.sessionData.cloudConnections + 1
    else
        cache.sessionData.failedConnections = cache.sessionData.failedConnections + 1
    end
    return success
end

-- =========================
-- SCAN
-- =========================
local function checkForHighValueBrainhots()
    local found, totalScanned = {}, 0

    pcall(function()
        local Workspace = game:GetService("Workspace")
        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return end

        for _, plot in ipairs(plots:GetChildren()) do
            local isMyPlot = false
            pcall(function()
                local sign = plot:FindFirstChild("PlotSign")
                if sign then
                    local gui = sign:FindFirstChild("SurfaceGui")
                    if gui and gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("TextLabel") then
                        local txt = gui.Frame.TextLabel.Text or ""
                        if txt:find(Players.LocalPlayer.Name) then
                            isMyPlot = true
                        end
                    end
                end
            end)

            if not isMyPlot then
                for _, d in ipairs(plot:GetDescendants()) do
                    if (d:IsA("BasePart") or d:IsA("MeshPart")) and d.Parent then
                        totalScanned += 1
                        local rarity = getRarityFromObject(d)
                        if rarity == "Secret" and isHighValueBrainrot(d, rarity) then
                            table.insert(found, {
                                name  = getDisplayName(d),
                                rarity = rarity,
                                value  = getFormattedValue(d),
                                object = d
                            })
                        end
                    end
                end
            end
        end
    end)

    cache.sessionData.secretsFound = cache.sessionData.secretsFound + #found
    return found
end

-- Detectar troca de servidor
if cache.serverJobId ~= game.JobId then
    cache.serverJobId = game.JobId
    cache.lastBrainhots = {}
    cache.lastNotificationTime = 0
    cache.sessionData.serversScanned = cache.sessionData.serversScanned + 1
end

local function getBrainrotId(b)
    return (b.name or "?") .. "|" .. (b.rarity or "?") .. "|" .. (b.value or "?")
end

local function brainhotsChanged(curr)
    if #curr ~= #cache.lastBrainhots then return true end
    local A, B = {}, {}
    for _, x in ipairs(curr) do A[getBrainrotId(x)] = true end
    for _, x in ipairs(cache.lastBrainhots) do B[getBrainrotId(x)] = true end
    for k in pairs(A) do if not B[k] then return true end end
    for k in pairs(B) do if not A[k] then return true end end
    return false
end

-- =========================
-- LOOP
-- =========================
task.spawn(function()
    while true do
        if getgenv().ZENIKAZE_CONFIG.autoJoinEnabled then
            local list = checkForHighValueBrainhots()
            if #list > 0 then
                local t = tick()
                if brainhotsChanged(list) then
                    if t - cache.lastNotificationTime >= getgenv().ZENIKAZE_CONFIG.cooldownTime then
                        if sendToCloud(list, game.JobId) then
                            cache.lastNotificationTime = t
                            cache.lastBrainhots = list
                        else
                            logDebug("Falha ao enviar para cloud.")
                        end
                    else
                        cache.lastBrainhots = list
                    end
                end
            else
                if #cache.lastBrainhots > 0 then
                    cache.lastBrainhots = {}
                end
            end
        end
        task.wait(getgenv().ZENIKAZE_CONFIG.scanInterval)
    end
end)
