local SemiInvisible = {}
SemiInvisible.active = false
SemiInvisible.animTrack = nil
SemiInvisible.fallConn = nil

function SemiInvisible:Start()
    if SemiInvisible.active then return end

    local character = LocalPlayer.Character
    if not character then return end

    SemiInvisible.active = true
    ScriptStatus.SemiInvisible = true
    SavedSettings.SemiInvisible = true
    SaveSystem.Save(SavedSettings)

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://127212897044971"

    SemiInvisible.animTrack = humanoid.Animator:LoadAnimation(anim)
    SemiInvisible.animTrack.Priority = Enum.AnimationPriority.Action4
    SemiInvisible.animTrack:Play(0)

    -- Wait for animation to load
    while SemiInvisible.animTrack.TimePosition < 0.1 do
        task.wait()
    end

    SemiInvisible.fallConn = RunService.Stepped:Connect(function()
        if not SemiInvisible.active then return end
        for _, basePart in pairs(character:GetDescendants()) do
            if basePart:IsA("BasePart") and basePart.Name ~= "HumanoidRootPart" and basePart.CanCollide then
                basePart.CanCollide = false
                basePart:AddTag("WasCollidable")
            end
        end
    end)

    -- Auto stop after 30 seconds
    task.delay(30, function()
        if SemiInvisible.active then
            SemiInvisible:Stop()
        end
    end)
