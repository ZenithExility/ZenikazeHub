-- Tab Settings
local SettingsTab = Window:CreateTab("Settings", 4483362458)

local JobIdInput = ""

SettingsTab:CreateButton({
    Name = "Rejoin Server",
    Callback = function()
        spawn(function()
            wait(0.5)
            game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer)
        end)
    end,
})

SettingsTab:CreateButton({
    Name = "Hop Server",
    Callback = function()
        spawn(function()
            local HttpService = game:GetService("HttpService")
            local TeleportService = game:GetService("TeleportService")
            
            pcall(function()
                local response = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
                local servers = HttpService:JSONDecode(response)
                local availableServers = {}
                
                for _, server in pairs(servers.data) do
                    if server.playing < server.maxPlayers and server.id ~= game.JobId then
                        table.insert(availableServers, server.id)
                    end
                end
                
                if #availableServers > 0 then
                    local randomServer = availableServers[math.random(1, #availableServers)]
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer)
                end
            end)
        end)
    end,
})

SettingsTab:CreateInput({
    Name = "Enter JobID",
    PlaceholderText = "Job ID aqui...",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        JobIdInput = Text
        getgenv().ZenikazeJobId = Text -- Atualiza Job ID compartilhado
