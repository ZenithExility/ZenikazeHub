local function scanForBases()
    if not ESP_SETTINGS.BaseESP then return end

    -- Procurar especificamente por bases com timer (como no EcstacyV2)
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if plotsFolder then
        for _, plot in pairs(plotsFolder:GetChildren()) do
            -- Procurar pelo bloco de timer da base
            local plotBlock = plot:FindFirstChild("Purchases", true) and 
                             plot.Purchases:FindFirstChild("PlotBlock", true)

            if plotBlock and plotBlock:FindFirstChild("Main") then
                local mainPart = plotBlock.Main
                if not BaseESPObjects[mainPart] then
                    createBaseESP(mainPart)
                end
            end
        end
    end

    -- Procurar por SpawnLocations como fallback
    for _, spawnLocation in pairs(Workspace:GetDescendants()) do
        if spawnLocation:IsA("SpawnLocation") and not BaseESPObjects[spawnLocation] then
            createBaseESP(spawnLocation)
        end
    end
end

local function updateBaseESP()
    if not ESP_SETTINGS.BaseESP then return end

    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    for basePart, espData in pairs(BaseESPObjects) do
        if not basePart or not basePart.Parent then
            removeBaseESP(basePart)
            continue
        end

        pcall(function()
            local distance = (myHRP.Position - basePart.Position).Magnitude

            if distance <= ESP_SETTINGS.MaxDistance then
                espData.billboard.Enabled = true

                local timeRemaining = getBaseTimeRemaining(basePart)
                local timeText = formatTime(timeRemaining)
                espData.timerLabel.Text = timeText
                espData.distanceLabel.Text = math.floor(distance) .. "m"

                -- Sistema de cores dinâmico melhorado
                if timeText == "UNLOCKED" or timeRemaining <= 0 then
                    -- Base desbloqueada - verde brilhante
                    espData.timerLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                    espData.frameStroke.Color = Color3.fromRGB(0, 255, 100)
                    espData.distanceLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                    espData.gradient.Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 50, 25)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 25, 15))
                    }
                elseif timeRemaining < 30 then
                    -- Prestes a desbloquear - verde
                    espData.timerLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                    espData.frameStroke.Color = Color3.fromRGB(100, 255, 100)
                    espData.distanceLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                    espData.gradient.Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(25, 50, 25)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(15, 25, 15))
                    }
                elseif timeRemaining < 60 then
                    -- Em breve - amarelo
                    espData.timerLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
                    espData.frameStroke.Color = Color3.fromRGB(255, 255, 100)
                    espData.distanceLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
                    espData.gradient.Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 50, 25)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 25, 15))
                    }
                else
                    -- Bloqueado - roxo (tema EcstacyV2)
                    espData.timerLabel.TextColor3 = Color3.fromRGB(180, 40, 180)
                    espData.frameStroke.Color = Color3.fromRGB(180, 40, 180)
                    espData.distanceLabel.TextColor3 = Color3.fromRGB(200, 60, 200)
                    espData.gradient.Color = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, Color3.fromRGB(45, 25, 45)),
                        ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 15, 25))
                    }
                end
            else
                espData.billboard.Enabled = false
            end
        end)
    end
end

