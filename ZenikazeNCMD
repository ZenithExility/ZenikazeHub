end

-- Verificar se o sistema de arquivos está disponível
local function checkFileSystemSupport()
    if not writefile or not readfile then
        debugLog("ERRO: Sistema de arquivos não suportado!", true)
        debugLog("Seu executor precisa ter writefile e readfile", true)
        return false
    end
    
    debugLog("Sistema de arquivos disponível - Modo CMD ativo", "SUCCESS")
    return true
end

-- Loop principal
task.spawn(function()
    -- Verificar suporte ao sistema de arquivos
    if not checkFileSystemSupport() then
        debugLog("Sistema encerrado - executor incompatível", true)
        return
    end
    
    debugLog("Scanner ativo (1M+ Range - Sistema CMD)")
    
    while true do
        local highValueBrainhots = checkForHighValueBrainhots()
        
        if #highValueBrainhots > 0 then
            local currentTime = tick()
            
            if brainhotsChanged(highValueBrainhots) then
                debugLog(string.format("%d Secrets 1M+ detectados!", #highValueBrainhots))
                
                if currentTime - cache.lastNotificationTime >= getgenv().ZENIKAZE_CONFIG.cooldownTime then
                    local cmdSuccess = sendToCmdSystem(highValueBrainhots, game.JobId)
                    
                    if cmdSuccess then
                        cache.lastNotificationTime = currentTime
                        cache.lastBrainhots = highValueBrainhots
                        debugLog("Dados enviados via arquivo para Sistema CMD!")
                    else
                        debugLog("Falha na comunicação - tentara novamente no proximo scan", true)
                    end
                else
                    local timeLeft = getgenv().ZENIKAZE_CONFIG.cooldownTime - (currentTime - cache.lastNotificationTime)
                    debugLog(string.format("Cooldown ativo - %d segundos restantes", math.ceil(timeLeft)))
                    cache.lastBrainhots = highValueBrainhots
                end
            end
        else
            if #cache.lastBrainhots > 0 then
                cache.lastBrainhots = {}
                debugLog("Cache limpo - Nenhum Secret 1M+ encontrado")
            end
        end
        
        task.wait(getgenv().ZENIKAZE_CONFIG.scanInterval)
    end
end)

-- Thread para estatísticas periódicas
task.spawn(function()
