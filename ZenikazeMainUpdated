local function toggleBaseOpacity(enabled)
    ScriptStatus.BaseOpacity = enabled
    SavedSettings.BaseOpacity = enabled
    SaveSystem.Save(SavedSettings)

    if enabled and not _G.ZenikazeScripts.BaseOpacity then
        _G.ZenikazeScripts.BaseOpacity = true
        
        -- Script Base Opacity inline
        pcall(function()
            local plotsFolder = workspace:FindFirstChild("Plots")
            if not plotsFolder then
                warn("❌ Pasta 'Plots' não encontrada no workspace")
                return
            end

            for _, plotModel in ipairs(plotsFolder:GetChildren()) do
                if plotModel:IsA("Model") then
                    local decorations = plotModel:FindFirstChild("Decorations")
                    if decorations and decorations:IsA("Folder") then
                        for _, decorModel in ipairs(decorations:GetChildren()) do
                            if decorModel:IsA("Model") then
                                for _, obj in ipairs(decorModel:GetDescendants()) do
                                    if obj:IsA("BasePart") then
                                        obj.Transparency = 0.7
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end)
        
        showNotification("✅ Base Opacity", "Bases ficaram transparentes!", 3)
    else
        showNotification("❌ Base Opacity", "Script desativado!", 2)
    end
end

local function removeAllAccessoriesFromPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character or targetPlayer == LocalPlayer then return end

    task.spawn(function()
        for _, item in ipairs(targetPlayer.Character:GetChildren()) do
            if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or 
               item:IsA("LayeredClothing") or item:IsA("BodyColors") or item:IsA("CharacterMesh") then
                pcall(function() 
                    item:Destroy()
                end)
                task.wait(0.1)
            end
        end
    end)
end

local function toggleFPSImune(enabled)
    ScriptStatus.FPSImune = enabled
    SavedSettings.FPSImune = enabled
    SaveSystem.Save(SavedSettings)

    if enabled then
        for _, targetPlayer in pairs(Players:GetPlayers()) do
            if targetPlayer ~= LocalPlayer and targetPlayer.Character then
                removeAllAccessoriesFromPlayer(targetPlayer)
            end
        end

        ActiveConnections.FPSImune = Players.PlayerAdded:Connect(function(newPlayer)
            if newPlayer ~= LocalPlayer then
                newPlayer.CharacterAdded:Connect(function()
                    task.wait(2)
                    removeAllAccessoriesFromPlayer(newPlayer)
                end)

                if newPlayer.Character then
                    removeAllAccessoriesFromPlayer(newPlayer)
                end
            end
        end)

        showNotification("✅ FPS Imune", "Removendo skins dos players...", 3)
    else
        if ActiveConnections.FPSImune then
            ActiveConnections.FPSImune:Disconnect()
            ActiveConnections.FPSImune = nil
        end
        showNotification("❌ FPS Imune", "Script desativado!", 2)
    end
end

