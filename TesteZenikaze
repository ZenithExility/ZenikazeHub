end)

local ThirdFloor = {}
ThirdFloor.platform = nil
ThirdFloor.active = false
ThirdFloor.connection = nil
ThirdFloor.isRising = false
ThirdFloor.RISE_SPEED = 15
ThirdFloor.TRANSPARENCY_RADIUS = 20
ThirdFloor.TRANSPARENCY_LEVEL = 0.5
ThirdFloor.transparentParts = {}
ThirdFloor.ORIGINAL_TRANSPARENCY = {}

local function setNearbyPartsTransparent()
    if not ThirdFloor.platform then return end
    local platformPos = ThirdFloor.platform.Position

    -- Remove transparency from parts that are now far away
    for part, _ in pairs(ThirdFloor.transparentParts) do
        if part and part:IsDescendantOf(workspace) then
            local dist = (part.Position - platformPos).Magnitude
            if dist > ThirdFloor.TRANSPARENCY_RADIUS then
                part.LocalTransparencyModifier = 0
                ThirdFloor.transparentParts[part] = nil
                ThirdFloor.ORIGINAL_TRANSPARENCY[part] = nil
            end
        end
    end

    -- Add transparency to nearby parts
    for _, part in ipairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and part ~= ThirdFloor.platform and not part:IsDescendantOf(LocalPlayer.Character) then
            local dist = (part.Position - platformPos).Magnitude
            if dist <= ThirdFloor.TRANSPARENCY_RADIUS and not ThirdFloor.transparentParts[part] then
                ThirdFloor.ORIGINAL_TRANSPARENCY[part] = part.Transparency
                part.LocalTransparencyModifier = ThirdFloor.TRANSPARENCY_LEVEL
                ThirdFloor.transparentParts[part] = true
            end
        end
    end
end

local function restoreParts()
    for part, _ in pairs(ThirdFloor.transparentParts) do
        if part and part:IsDescendantOf(workspace) then
            part.LocalTransparencyModifier = 0
        end
    end
    ThirdFloor.transparentParts = {}
    ThirdFloor.ORIGINAL_TRANSPARENCY = {}
end

local function canRise()
    if not ThirdFloor.platform then return false end
    local origin = ThirdFloor.platform.Position + Vector3.new(0, ThirdFloor.platform.Size.Y / 2, 0)
    local direction = Vector3.new(0, 2, 0)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {ThirdFloor.platform, LocalPlayer.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local result = workspace:Raycast(origin, direction, raycastParams)
    return not result
end

function ThirdFloor:Start()
    if ThirdFloor.active then return end

    local character = LocalPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    ThirdFloor.active = true
    ScriptStatus.ThirdFloor = true
    SavedSettings.ThirdFloor = true
    SaveSystem.Save(SavedSettings)

    -- Create platform
    ThirdFloor.platform = Instance.new("Part")
    ThirdFloor.platform.Size = Vector3.new(6, 0.5, 6)
    ThirdFloor.platform.Anchored = true
    ThirdFloor.platform.CanCollide = true
    ThirdFloor.platform.Transparency = 0.5
    ThirdFloor.platform.Material = Enum.Material.Neon
    ThirdFloor.platform.Color = Color3.fromRGB(100, 100, 255)
    ThirdFloor.platform.Position = rootPart.Position - Vector3.new(0, rootPart.Size.Y / 2 + ThirdFloor.platform.Size.Y / 2, 0)
    ThirdFloor.platform.Parent = workspace

    ThirdFloor.isRising = true

    -- Start update loop
    ThirdFloor.connection = RunService.Heartbeat:Connect(function(dt)
        if ThirdFloor.platform and ThirdFloor.active and rootPart then
            local currentPos = ThirdFloor.platform.Position
            local newPosXZ = Vector3.new(rootPart.Position.X, currentPos.Y, rootPart.Position.Z)

            if ThirdFloor.isRising and canRise() then
                ThirdFloor.platform.Position = newPosXZ + Vector3.new(0, dt * ThirdFloor.RISE_SPEED, 0)
            else
                ThirdFloor.isRising = false
                ThirdFloor.platform.Position = newPosXZ
            end

            setNearbyPartsTransparent()
        end
    end)

    -- Handle character death
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.Died:Connect(function()
            ThirdFloor:Stop()
        end)
    end
end

function ThirdFloor:Stop()
    if ThirdFloor.platform then
        ThirdFloor.platform:Destroy()
        ThirdFloor.platform = nil
    end
    ThirdFloor.active = false
    ThirdFloor.isRising = false
    ScriptStatus.ThirdFloor = false
    SavedSettings.ThirdFloor = false
    SaveSystem.Save(SavedSettings)

    if ThirdFloor.connection then
        ThirdFloor.connection:Disconnect()
        ThirdFloor.connection = nil
    end
    restoreParts()
end

LocalPlayer.CharacterAdded:Connect(function()
    if ThirdFloor.active then
        ThirdFloor:Stop()
    end
end)

