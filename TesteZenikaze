        local function updateProgress(targetProgress, statusText, forceUpdate)
            if not loadingScreenGui then return end
            
            local elements = {
                progressBar = loadingScreenGui.BackgroundFrame.CenterContainer.ProgressContainer.ProgressBar,
                percentageLabel = loadingScreenGui.BackgroundFrame.CenterContainer.ProgressContainer.PercentageLabel,
                statusLabel = loadingScreenGui.BackgroundFrame.CenterContainer.StatusLabel
            }
            
            targetProgress = math.clamp(targetProgress, 0, 100)
            
            if targetProgress < progressValue then
                return
            end
            
            if statusText then
                elements.statusLabel.Text = statusText
            end
            
            if forceUpdate then
                elements.progressBar.Size = UDim2.new(targetProgress / 100, 0, 1, 0)
                elements.percentageLabel.Text = targetProgress .. "%"
                progressValue = targetProgress
                return
            end
            
            local animationSpeed
            if targetProgress >= 90 then
                animationSpeed = 1.5
            else
                animationSpeed = 0.14
            end
            
            local progressTween = createTween(elements.progressBar,
                TweenInfo.new(animationSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Size = UDim2.new(targetProgress / 100, 0, 1, 0)}
            )
            progressTween:Play()
            
            local startProgress = progressValue
            spawn(function()
                local duration = animationSpeed
                local startTime = tick()
                
                while tick() - startTime < duration and not isCompleted do
                    local elapsed = tick() - startTime
                    local currentProgress = startProgress + (targetProgress - startProgress) * (elapsed / duration)
                    elements.percentageLabel.Text = math.floor(currentProgress) .. "%"
                    task.wait()
                end
                
                elements.percentageLabel.Text = targetProgress .. "%"
                progressValue = targetProgress
            end)
        end

        local function startAutoProgress()
            spawn(function()
                local statusMessages = {
                    [10] = "Loading components...",
                    [25] = "Scanning plots...",
                    [40] = "Equipping tools...",
                    [55] = "Navigating to target...",
                    [70] = "Positioning character...",
                    [85] = "Final approach..."
                }
                
                while not scriptCompleted and progressValue < 89 do
                    task.wait(0.14)
                    if not scriptCompleted and progressValue < 89 then
                        progressValue = progressValue + 1
                        
                        local statusText = statusMessages[progressValue] or nil
                        if statusText then
                            updateProgress(progressValue, statusText, true)
                        else
                            updateProgress(progressValue, nil, true)
                        end
                    end
                end
                
                while not scriptCompleted do
                    task.wait(0.1)
                end
                
                updateProgress(100, "Teleported Successfully...", false)
                
                task.wait(1)
            end)
        end

        local function resetCharacter()
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.Health = 0
            end
            
            local character = player.CharacterAdded:Wait()
            
            return character
        end

        local function runBrainrotScript()
            local character = player.Character or player.CharacterAdded:Wait()
            local humanoid = character:WaitForChild("Humanoid")
            local hrp = character:WaitForChild("HumanoidRootPart")
            local backpack = player:WaitForChild("Backpack")
            
            local function EquipCoilCombo()
                humanoid:UnequipTools()
                task.wait(0.1)
                local combo = backpack:FindFirstChild("Coil Combo")
                if combo then
                    humanoid:EquipTool(combo)
                    return true
                else
                    return false
                end
            end

            local function getBestBrainrotPosition()
                local plots = workspace:FindFirstChild("Plots")
                if not plots then 
                    return nil, nil 
                end
                
                local bestBrainrot, bestEarning = nil, 0
                
                for _, plot in ipairs(plots:GetChildren()) do
                    local sign = plot:FindFirstChild("PlotSign")
                    if sign then
                        local txt = sign:FindFirstChild("TextLabel") and sign.TextLabel.Text or ""
                        if txt:find(player.Name) then
                            continue
                        end
                    end
                    
                    for _, d in ipairs(plot:GetDescendants()) do
                        if d:IsA("TextLabel") and d.Text and d.Text:find("/s") then
                            local txt = d.Text:gsub(",", "")
                            local a, b = txt:match("([%d%.]+)([kKmMbB]?)")
                            local earning = tonumber(a) or 0
                            
                            if b then
                                b = b:lower()
                                if b == "k" then earning = earning * 1e3
                                elseif b == "m" then earning = earning * 1e6
                                elseif b == "b" then earning = earning * 1e9 end
                            end
                            
                            local p = d.Parent
                            while p and not p:IsA("Model") do
                                p = p.Parent
                            end
                            
                            if p and earning > bestEarning then
                                local part = p:FindFirstChildWhichIsA("BasePart", true)
                                if part then
                                    bestEarning = earning
                                    bestBrainrot = part
                                end
                            end
                        end
                    end
                end
                
                return bestBrainrot and bestBrainrot.Position or nil, bestBrainrot
            end

            local function fullStop()
                if hrp then
                    hrp.Velocity = Vector3.zero
                    hrp.RotVelocity = Vector3.zero
                    for _ = 1, 3 do
                        task.wait()
                        hrp.Velocity = Vector3.zero
                        hrp.RotVelocity = Vector3.zero
                    end
                end
                if humanoid then
                    humanoid:Move(Vector3.new(0,0,0))
                    pcall(function() humanoid:MoveTo(hrp.Position) end)
                end
            end

            local function equipQuantumClonerAndUse()
                humanoid:UnequipTools()
                task.wait(0.01)
                
                local cloner = backpack:FindFirstChild("Quantum Cloner")
                if cloner then
                    humanoid:EquipTool(cloner)
                    task.wait(0.01)
                    
                    pcall(function()
                        ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Net"):WaitForChild("RE/UseItem"):FireServer()
                    end)
                    task.wait(0.01)
                    
                    pcall(function()
                        ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Net"):WaitForChild("RE/QuantumCloner/OnTeleport"):FireServer()
                    end)
                    
                    task.wait(0.1)
                    
                    humanoid:UnequipTools()
                    
                    scriptCompleted = true
                    
                    return true
                else
                    return false
                end
            end

            local function GoToBestBrainrot()
                if not EquipCoilCombo() then
                    return false
                end
                
                local targetPos, brainrotPart = getBestBrainrotPosition()
                if not targetPos or not brainrotPart then 
                    task.wait(2)
                    return false
                end
                
                local speed = 45
                local xOptions = {-465, -353}
                local closestX = xOptions[1]
                local minDist = math.huge
                
                for i = 1, #xOptions do
                    local d = math.abs(brainrotPart.Position.X - xOptions[i])
                    if d < minDist then
                        minDist = d
                        closestX = xOptions[i]
                    end
                end

                local phase = "ascend50"
                local connection
                local finalPhaseStart = nil
                local velocityToMoveToTriggered = false
                local completed = false

                connection = RunService.Heartbeat:Connect(function()
                    if not hrp or not hrp.Parent then
                        connection:Disconnect()
                        fullStop()
                        return
                    end

                    if phase == "ascend50" then
                        local diffY = 57 - hrp.Position.Y
                        if math.abs(diffY) > 1 then
                            hrp.Velocity = Vector3.new(0, diffY > 0 and speed or -speed, 0)
                            humanoid:Move(Vector3.new(-410, hrp.Position.Y, hrp.Position.Z) - hrp.Position)
                        else
                            hrp.Velocity = Vector3.zero
                            phase = "descend30"
                        end
                        
                    elseif phase == "descend30" then
                        local diffY = 57 - hrp.Position.Y
                        if math.abs(diffY) > 1 then
                            hrp.Velocity = Vector3.new(0, diffY > 0 and speed or -speed, 0)
                            humanoid:Move(Vector3.new(targetPos.X, hrp.Position.Y, hrp.Position.Z) - hrp.Position)
                        else
                            hrp.Velocity = Vector3.zero
                            phase = "moveXBrainrot"
                        end

                    elseif phase == "moveXBrainrot" then
                        local dirX = Vector3.new(targetPos.X, hrp.Position.Y, hrp.Position.Z) - hrp.Position
                        if math.abs(dirX.X) > 2 then
                            hrp.Velocity = Vector3.new(dirX.X > 0 and speed or -speed, 0, 0)
                            humanoid:Move(dirX)
                        else
                            hrp.Velocity = Vector3.zero
                            phase = "moveZBrainrot"
                        end

                    elseif phase == "moveZBrainrot" then
                        local dirZ = Vector3.new(hrp.Position.X, hrp.Position.Y, targetPos.Z) - hrp.Position
                        if math.abs(dirZ.Z) > 2 then
                            hrp.Velocity = Vector3.new(0,0,dirZ.Z > 0 and speed or -speed)
                            humanoid:Move(dirZ)
                        else
                            hrp.Velocity = Vector3.zero
                            phase = "closestX"
                        end

                    elseif phase == "closestX" then
                        local dir = Vector3.new(closestX, hrp.Position.Y, hrp.Position.Z) - hrp.Position
                        if math.abs(dir.X) > 1 then
                            hrp.Velocity = Vector3.new(dir.X > 0 and speed or -speed, 0, 0)
                        else
                            hrp.Velocity = Vector3.zero
                            phase = "brainY"
                        end

                    elseif phase == "brainY" then
                        local targetY = brainrotPart.Position.Y + 2
                        local diffY = targetY - hrp.Position.Y
                        if math.abs(diffY) > 1 then
                            hrp.Velocity = Vector3.new(0, diffY > 0 and speed or -speed, 0)
                        else
                            hrp.Velocity = Vector3.zero
                            phase = "toBrainrot"
                        end

                    elseif phase == "toBrainrot" then
                        if not finalPhaseStart then
                            finalPhaseStart = tick()
                        end
                        
                        local dir = (brainrotPart.Position - hrp.Position)
                        local dist = dir.Magnitude

                        if not velocityToMoveToTriggered and (tick() - finalPhaseStart) < 1 and dist > 1 then
                            hrp.Velocity = dir.Unit * speed
                        elseif not velocityToMoveToTriggered then
                            velocityToMoveToTriggered = true
                            hrp.Velocity = Vector3.zero
                            humanoid:Move(Vector3.new(0,0,0))
                            pcall(function() humanoid:MoveTo(hrp.Position) end)
                            humanoid:MoveTo(brainrotPart.Position)
                            
                            local moveConn, moved = nil, false
                            moveConn = humanoid.MoveToFinished:Connect(function()
                                if moved then return end
                                moved = true
                                if moveConn then moveConn:Disconnect() end
                                fullStop()
                                equipQuantumClonerAndUse()
                                completed = true
                                connection:Disconnect()
                            end)
                            
                            task.delay(0.25, function()
                                if not moved then
                                    if moveConn then moveConn:Disconnect() end
                                    fullStop()
                                    equipQuantumClonerAndUse()
                                    completed = true
                                    if connection then connection:Disconnect() end
                                end
                            end)
                        end
                    end
                end)
                
                local waitStart = tick()
                while not completed and (tick() - waitStart) < 30 do
                    task.wait(0.1)
                end
                
                if not completed then
                    if connection then connection:Disconnect() end
                    fullStop()
                    equipQuantumClonerAndUse()
                end
                
                return true
            end

            return GoToBestBrainrot()
        end

        local function completeLoading(success)
            isCompleted = true
            
            if success then
                task.wait(1)
            else
                updateProgress(50, "Execution failed")
                task.wait(2)
            end
            
            cleanupAnimations()
            
            if loadingScreenGui then
                local fadeInfo = TweenInfo.new(CONFIG.ANIMATIONS.FADE_DURATION, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                
                local elements = loadingScreenGui:GetDescendants()
                for _, element in pairs(elements) do
                    if element:IsA("GuiObject") then
                        spawn(function()
                            createTween(element, fadeInfo, {
                                BackgroundTransparency = 1,
                                TextTransparency = 1
                            }):Play()
                        end)
                    end
                end
                
                task.wait(CONFIG.ANIMATIONS.FADE_DURATION + 0.1)
                loadingScreenGui:Destroy()
                loadingScreenGui = nil
            end
        end

        local function main()
            local elements = createMinimalistLoadingScreen()
            
            updateProgress(0, "Initializing...")
            
            startAutoProgress()
            
            resetCharacter()
            
            local success = false
            local attempts = 0
            local maxAttempts = 3
            
            while not success and attempts < maxAttempts do
                attempts = attempts + 1
                
                success = runBrainrotScript()
                
                if not success and attempts < maxAttempts then
                    task.wait(1)
                end
            end
            
            completeLoading(success)
        end

        main()
    end
    
    -- Executa o script principal
    executeTPHighest()
    showNotification("TP Highest", "Iniciando teleporte para o highest brainrot...", 3)
end)

