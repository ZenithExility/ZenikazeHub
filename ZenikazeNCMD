-- Função para testar conexão
local function testConnection()
    debugLog("Testando conexão com sistema híbrido...")
    
    local testMethods = {
        function()
            if http_request then
                return http_request({
                    Url = getgenv().ZENIKAZE_CONFIG.pythonEndpoint .. "/status",
                    Method = "GET",
                    Headers = {
                        ["User-Agent"] = "Zenikaze-Test/1.0"
                    }
                })
            end
            return false
        end,
        function()
            if request then
                return request({
                    Url = getgenv().ZENIKAZE_CONFIG.pythonEndpoint .. "/status",
                    Method = "GET"
                })
            end
            return false
        end
    }
    
    for _, method in ipairs(testMethods) do
        local success, response = pcall(method)
        if success and response and response.StatusCode == 200 then
            debugLog("Conexão com sistema híbrido OK!")
            cache.hybridSystemStatus = "CONNECTED"
            return true
        end
    end
    
    debugLog("Falha ao conectar - verifique se o Python está rodando", true)
    cache.hybridSystemStatus = "OFFLINE"
    return false
end

-- Loop principal
task.spawn(function()
    debugLog("Scanner ativo (1M+ Range - Sistema Híbrido)")
    
    -- Testar conexão inicial
    task.wait(2)
    testConnection()
    
    while true do
        local highValueBrainhots = checkForHighValueBrainhots()
        
        if #highValueBrainhots > 0 then
            local currentTime = tick()
            
            if brainhotsChanged(highValueBrainhots) then
                debugLog(string.format("%d Secrets 1M+ detectados!", #highValueBrainhots))
                
                if currentTime - cache.lastNotificationTime >= getgenv().ZENIKAZE_CONFIG.cooldownTime then
                    local hybridSuccess = sendToHybridSystem(highValueBrainhots, game.JobId)
                    
                    if hybridSuccess then
                        cache.lastNotificationTime = currentTime
                        cache.lastBrainhots = highValueBrainhots
                        debugLog("Dados enviados -> Sistema executa comandos automaticamente!")
                    else
                        debugLog("Falha na comunicação - tentara novamente no proximo scan", true)
                    end
                else
                    local timeLeft = getgenv().ZENIKAZE_CONFIG.cooldownTime - (currentTime - cache.lastNotificationTime)
                    debugLog(string.format("Cooldown ativo - %d segundos restantes", math.ceil(timeLeft)))
                    cache.lastBrainhots = highValueBrainhots
                end
            end
        else
            if #cache.lastBrainhots > 0 then
                cache.lastBrainhots = {}
                debugLog("Cache limpo - Nenhum Secret 1M+ encontrado")
            end
        end
        
        task.wait(getgenv().ZENIKAZE_CONFIG.scanInterval)
    end
end)

