-- Função para logs
local function debugLog(message, isError)
    local prefix = isError and "[X] Zenikaze ERROR:" or "[*] Zenikaze:"
    local fullMessage = string.format("%s %s", prefix, message)
    
    print(fullMessage)
    
    if getgenv().ZENIKAZE_CONFIG.debugMode then
        warn(string.format("[DEBUG %s] %s", os.date("%H:%M:%S"), message))
    end
end

