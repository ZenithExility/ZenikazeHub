-- Gerar ID único do usuário
local function generateUserId()
    if getgenv().ZENIKAZE_CONFIG.userId == "" then
        local chars = "abcdefghijklmnopqrstuvwxyz0123456789"
        local userId = ""
        for i = 1, 12 do
            local randIndex = math.random(1, #chars)
            userId = userId .. string.sub(chars, randIndex, randIndex)
        end
        getgenv().ZENIKAZE_CONFIG.userId = userId
    end
    return getgenv().ZENIKAZE_CONFIG.userId
end

-- Verificar se é servidor privado
local function isPrivateServer()
    local success, result = pcall(function()
        return game.PrivateServerId ~= "" and game.PrivateServerOwnerId ~= 0
    end)
    return success and result
end

-- Verificar se servidor está lotado
local function isServerCrowded()
    local currentPlayers = #Players:GetPlayers()
    
    -- Rejeitar se tem 8+ players ou mais que o limite configurado
    return currentPlayers >= 8 or currentPlayers > getgenv().ZENIKAZE_CONFIG.maxPlayersToJoin
end

local function buildJoinLink(placeId, jobId)
    -- Verificar se é server privado antes de criar link
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and isPrivateServer() then
        return nil
    end
    
    -- Verificar se está lotado
    if isServerCrowded() then
        return nil
    end
    
    -- Para servers públicos, usar link direto do Roblox
    return string.format(
        "https://www.roblox.com/games/%d/Brainrot-Simulator?gameInstanceId=%s",
        placeId,
        jobId
    )
end

-- Function to extract brainrot value from object (ADAPTADO PARA 1M+)
local function getBrainrotValue(object)
    if not object or not object.Parent then return 0 end
    
    local success, value = pcall(function()
        for _, descendant in pairs(object:GetDescendants()) do
            if descendant:IsA("TextLabel") and descendant.Text then
                local text = descendant.Text
                
                -- Formato B (billions): "1.5B/sec"
                local bValue = text:match("([%d%.]+)B/?[sS]?e?c?")
                if bValue then
                    local num = tonumber(bValue)
                    if num then
                        return num * 1000000000
                    end
                end
                
                -- Formato: "5.2M/sec", "10M/sec", etc.
                local millionValue = text:match("([%d%.]+)M/?[sS]?e?c?")
                if millionValue then
                    local num = tonumber(millionValue)
                    if num then
                        return num * 1000000
                    end
                end
                
                -- Formato: "5,000,000/sec", "10,000,000", etc.
                local commaValue = text:match("([%d,]+),000,000/?[sS]?e?c?")
                if commaValue then
                    local cleanNum = commaValue:gsub(",", "")
                    local num = tonumber(cleanNum)
                    if num then
                        return num * 1000000
                    end
                end
                
                -- Formato: números de 7+ dígitos (mudado para detectar 1M+)
                local sevenDigits = text:match("([%d]+)/?[sS]?e?c?")
                if sevenDigits and #sevenDigits >= 7 then
                    local num = tonumber(sevenDigits)
                    if num and num >= 1000000 then -- Mudado para 1M+
                        return num
                    end
                end
                
                -- Formato em K: "1000K/sec", etc.
                local kValue = text:match("([%d%.]+)K/?[sS]?e?c?")
                if kValue then
                    local num = tonumber(kValue)
                    if num then
                        return num * 1000
                    end
                end
            end
        end
        return 0
    end)
    
    return success and value or 0
end

-- Function to check if brainrot value is 1M+ (MUDADO PARA 1M+)
local function isHighValueBrainrot(object, rarity)
    if not object or not object.Parent then return false end
    
    -- Só aceitar Secrets
    if rarity ~= "Secret" then
        return false
    end
    
    -- Get the actual brainrot value
    local brainrotValue = getBrainrotValue(object)
    
    -- Check if value is 1M or more (mudado de 10M para 1M)
    return brainrotValue >= getgenv().ZENIKAZE_CONFIG.minSecretValue
end

local function getRarityFromObject(object)
    if not object or not object.Parent then return nil end
    
    local success, result = pcall(function()
        for _, descendant in pairs(object:GetDescendants()) do
            if descendant.Name == "Rarity" and descendant:IsA("TextLabel") then
                local rarityText = descendant.Text:gsub("%s+", "")
                return rarityText
            end
            
            if descendant.Name == "DisplayName" and descendant:IsA("TextLabel") then
                local displayText = descendant.Text
                -- Extract rarity from display name
                for rarity in displayText:gmatch("%[([^%]]+)%]") do
                    return rarity
                end
            end
        end
        
        -- Detect by color
        if object:IsA("BasePart") then
            local color = object.Color
            if color == Color3.fromRGB(100, 100, 100) then
                return "Secret"
            end
        end
        
        return nil
    end)
    
    return success and result or nil
end

local function getDisplayName(object)
    local success, result = pcall(function()
        for _, child in pairs(object:GetDescendants()) do
            if child.Name == "DisplayName" and child:IsA("TextLabel") then
                return child.Text
            end
        end
        return object.Name
    end)
    
    return success and result or (object.Name or "Brainrot")
end

local function getFormattedValue(object)
    local brainrotValue = getBrainrotValue(object)
    
    if brainrotValue >= 1000000000 then
        local billions = brainrotValue / 1000000000
        return string.format("%.1fB/sec", billions)
    elseif brainrotValue >= 1000000 then
        local millions = brainrotValue / 1000000
        return string.format("%.1fM/sec", millions)
    elseif brainrotValue >= 1000 then
        local thousands = brainrotValue / 1000
        return string.format("%.1fK/sec", thousands)
    else
        return string.format("%.0f/sec", brainrotValue)
    end
end

-- Função para enviar dados para Firebase (SEM WEBHOOK)
local function sendToCloud(foundBrainhots, jobId)
    -- Verificar se deve evitar servers privados/lotados
    if getgenv().ZENIKAZE_CONFIG.avoidPrivateServers and isPrivateServer() then
        return false
    end
    
    if isServerCrowded() then
        return false
    end
    
    -- Só enviar se encontrou brainhots válidos
    if #foundBrainhots == 0 then
        return false
    end
    
    local userId = generateUserId()
    local timestamp = tostring(os.time())
    
    -- Construir link de join apenas para servers públicos
    local joinLink = nil
    if getgenv().ZENIKAZE_CONFIG.onlyPublicServers then
        joinLink = buildJoinLink(game.PlaceId, jobId)
    end
    
    -- Se não conseguiu criar link válido, não enviar
    if not joinLink then
        return false
    end
    
    local serverData = {
        userId = userId,
        timestamp = DateTime.now():ToIsoDate(),
        server = {
            jobId = jobId,
            placeId = game.PlaceId,
            playerCount = #Players:GetPlayers(),
            maxPlayers = Players.MaxPlayers,
            joinLink = joinLink,
            isPrivate = isPrivateServer(),
            isCrowded = isServerCrowded()
        },
        secrets = {},
        statistics = {
            totalSecrets = #foundBrainhots,
            highestValue = 0,
            sessionData = cache.sessionData
        },
        client_source = "roblox_lua_script",
        status = "active"
    }
    
    -- Processar brainhots encontrados
    for _, brainhotInfo in ipairs(foundBrainhots) do
        local rawValue = getBrainrotValue(brainhotInfo.object) or 0
        if rawValue > serverData.statistics.highestValue then
            serverData.statistics.highestValue = rawValue
        end
        
        table.insert(serverData.secrets, {
            name = brainhotInfo.name,
            rarity = brainhotInfo.rarity,
            value = brainhotInfo.value,
            rawValue = rawValue,
            formattedValue = getFormattedValue(brainhotInfo.object)
        })
    end
    
    local jsonData = HttpService:JSONEncode(serverData)
    
    -- URLs do Firebase
    local firebaseEndpoint = string.format("%s/zenikaze/servers/%s/%s.json", 
        getgenv().ZENIKAZE_CONFIG.firebaseUrl, userId, timestamp)
    local userEndpoint = string.format("%s/zenikaze/users/%s.json", 
        getgenv().ZENIKAZE_CONFIG.firebaseUrl, userId)
    
    -- Atualizar dados do usuário
    local userData = {
        lastActive = DateTime.now():ToIsoDate(),
        totalServers = cache.sessionData.serversScanned,
        totalSecrets = cache.sessionData.secretsFound,
        highestValue = serverData.statistics.highestValue,
        playerName = player.Name
    }
    
    -- Tentar enviar para o Firebase
    local cloudMethods = {
        function() -- Método http_request
            if http_request then
                local serverResponse = http_request({
                    Url = firebaseEndpoint,
                    Method = "PUT",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = jsonData
                })
                
                local userResponse = http_request({
                    Url = userEndpoint,
                    Method = "PATCH",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = HttpService:JSONEncode(userData)
                })
                
                return serverResponse and userResponse
            end
            return false
        end,
        function() -- Método request
            if request then
                local serverResponse = request({
                    Url = firebaseEndpoint,
                    Method = "PUT",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = jsonData
                })
                
                local userResponse = request({
                    Url = userEndpoint,
                    Method = "PATCH",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = HttpService:JSONEncode(userData)
                })
                
                return serverResponse and userResponse
            end
            return false
        end,
        function() -- Método syn.request
            if syn and syn.request then
                local serverResponse = syn.request({
                    Url = firebaseEndpoint,
                    Method = "PUT",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = jsonData
                })
                
                local userResponse = syn.request({
                    Url = userEndpoint,
                    Method = "PATCH",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = HttpService:JSONEncode(userData)
                })
                
                return serverResponse and userResponse
            end
            return false
        end
    }
    
    local cloudSuccess = false
    for _, method in ipairs(cloudMethods) do
        local success, response = pcall(method)
        if success and response then
            cloudSuccess = true
            cache.sessionData.cloudConnections = cache.sessionData.cloudConnections + 1
            break
        end
    end
    
    if not cloudSuccess then
        cache.sessionData.failedConnections = cache.sessionData.failedConnections + 1
    end
    
    return cloudSuccess
end

local function checkForHighValueBrainhots()
    local found = {}
    local totalScanned = 0
    
    local success = pcall(function()
        local workspace = game:GetService("Workspace")
        local plotsFolder = workspace:FindFirstChild("Plots")
        
        if not plotsFolder then 
            return 
        end
        
        for _, plot in pairs(plotsFolder:GetChildren()) do
            local isMyPlot = false
            
            -- Check if this is my plot
            pcall(function()
                local plotSign = plot:FindFirstChild("PlotSign")
                if plotSign and plotSign:FindFirstChild("SurfaceGui") then
                    local text = plotSign.SurfaceGui.Frame.TextLabel.Text
                    if text:find(player.Name) then
                        isMyPlot = true
                    end
                end
            end)
            
            if not isMyPlot then
                for _, descendant in pairs(plot:GetDescendants()) do
                    if (descendant:IsA("BasePart") or descendant:IsA("MeshPart")) and descendant.Parent then
                        totalScanned = totalScanned + 1
                        
                        local rarity = getRarityFromObject(descendant)
                        
                        -- Verificar se é Secret com 1M+ (mudado de 10M+)
                        if rarity == "Secret" then
                            -- Check if brainrot meets criteria
                            if isHighValueBrainrot(descendant, rarity) then
                                local displayName = getDisplayName(descendant)
                                local formattedValue = getFormattedValue(descendant)
                                
                                -- Only add if we have valid rarity
                                if rarity then
                                    table.insert(found, {
                                        name = displayName,
                                        rarity = rarity,
                                        value = formattedValue,
                                        object = descendant
                                    })
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    
    cache.sessionData.secretsFound = cache.sessionData.secretsFound + #found
    
    return found
end

