    SemiInvisible.active = false
    ScriptStatus.SemiInvisible = false
    SavedSettings.SemiInvisible = false
    SaveSystem.Save(SavedSettings)

    if SemiInvisible.fallConn then
        SemiInvisible.fallConn:Disconnect()
        SemiInvisible.fallConn = nil
    end

    if SemiInvisible.animTrack then
        SemiInvisible.animTrack:Stop()
        SemiInvisible.animTrack = nil
    end

    local character = LocalPlayer.Character
    if character then
        for _, basePart in ipairs(character:GetDescendants()) do
            if basePart:IsA("BasePart") and basePart.Name ~= "HumanoidRootPart" and basePart:HasTag("WasCollidable") then
                basePart.CanCollide = true
                basePart:RemoveTag("WasCollidable")
            end
        end
    end
end

