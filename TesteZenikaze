local AimbotSystem = {
    active = false,
    MAX_DISTANCE = 200,
    COOLDOWN = 0.2,
    lastFire = 0
}

local REMOTE_CHAINS = {
    {"Packages","Net","RE/UseItem"},
    {"Net","RE/UseItem"},
    {"RE/UseItem"},
    {"Remotes","UseItem"},
    {"UseItem"},
    {"Packages","Net","RE/LaserCape"},
    {"Net","RE/LaserCape"},
    {"RE/LaserCape"},
    {"Remotes","LaserCape"},
    {"LaserCape"},
}

local function getByChain(root, chain)
    local node = root
    for i = 1, #chain do
        node = node and node:FindFirstChild(chain[i])
        if not node then return nil end
    end
    return node
end

local function getClosestTargetHRP()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local myPos = hrp.Position
    local closestHRP, best = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local thrp = p.Character:FindFirstChild("HumanoidRootPart")
            if thrp then
                local d = (thrp.Position - myPos).Magnitude
                if d < best then
                    best = d
                    closestHRP = thrp
                end
            end
        end
    end
    if best <= AimbotSystem.MAX_DISTANCE then
        return closestHRP
    end
end

local function fireRemotes(targetHRP)
    local args = { targetHRP.Position, targetHRP }
    for _, chain in ipairs(REMOTE_CHAINS) do
        local remote = getByChain(ReplicatedStorage, chain)
        if remote and remote.FireServer then
            local ok = pcall(function()
                remote:FireServer(unpack(args))
            end)
            if ok then return true end
        end
    end
    return false
end

local function executeAimbot()
    if not AimbotSystem.active then return end
    local now = tick()
    if now - AimbotSystem.lastFire < AimbotSystem.COOLDOWN then return end
    AimbotSystem.lastFire = now
    local targetHRP = getClosestTargetHRP()
    if not targetHRP then return end
    fireRemotes(targetHRP)
end

local function stopAimbotHelper()
    if AimbotSystem.inputConnection then
        AimbotSystem.inputConnection:Disconnect()
        AimbotSystem.inputConnection = nil
    end
    if AimbotSystem.touchConnection then
        AimbotSystem.touchConnection:Disconnect()
        AimbotSystem.touchConnection = nil
    end
    AimbotSystem.active = false
end

local function startAimbotHelper()
    AimbotSystem.active = true

    AimbotSystem.inputConnection = UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Enum.KeyCode.Q then
            executeAimbot()
        elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
            executeAimbot()
        elseif input.UserInputType == Enum.UserInputType.Touch then
            executeAimbot()
        end
    end)

    if UserInputService.TouchEnabled and UserInputService.TouchTap then
        AimbotSystem.touchConnection = UserInputService.TouchTap:Connect(function(_, processed)
            if not processed then executeAimbot() end
        end)
    end
end

